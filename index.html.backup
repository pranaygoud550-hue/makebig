  function initProjectWizard() {
    wizardState.step = 1;
    wizardState.entry = "";
    wizardState.category = "";
    wizardState.skills = [];
    wizardState.quoteIndex = 0;
    clearWizardInputs();
    const joinExpect = document.getElementById("wizardJoinExpectSalary");
    if (joinExpect) delete joinExpect.dataset.liveBound;
    const invitePanel = document.getElementById("inviteMembersPanel");
    if (invitePanel) invitePanel.classList.add("hidden");
    renderCategoryCards();
    renderSkillCards();
    renderParticles();
    startQuotes();
    updateWizardStep();
  }

  function clearWizardInputs() {
    ["wizardProjectName", "wizardShortDesc", "wizardTeamSize", "wizardDeadline", "wizardVision", "wizardMinSalary", "wizardMaxSalary", "wizardJoinExpectSalary"].forEach(id => {
      const element = document.getElementById(id);
      if (element) element.value = "";
    });
    const coverImage = document.getElementById("wizardCoverImage");
    if (coverImage) coverImage.value = "";
    setWizardError("");
  }

  function renderCategoryCards() {
    const grid = document.getElementById("categoryGrid");
    grid.innerHTML = "";
    wizardCategories.forEach(category => {
      const card = document.createElement("div");
      card.className = `flow-card ${wizardState.category === category.id ? "selected" : ""}`;
      card.onclick = () => selectCategory(category.id);
      const blurb = category.blurb ? category.blurb : `Build with creators in ${category.title}.`;
      card.innerHTML = `
        <h3>${category.title}</h3>
        <p>${blurb}</p>
      `;
      grid.appendChild(card);
    });
  }

  function renderSkillCards() {
    const grid = document.getElementById("skillGrid");
    grid.innerHTML = "";
    const skills = wizardSkillsMap[wizardState.category] || [];

    if (skills.length === 0) {
      const emptyCard = document.createElement("div");
      emptyCard.className = "flow-card";
      emptyCard.style.cursor = "default";
      emptyCard.innerHTML = "<h3>Select a category first</h3><p>Skills will appear once category is selected.</p>";
      grid.appendChild(emptyCard);
      return;
    }

    skills.forEach(skill => {
      const selected = wizardState.skills.includes(skill);
      const card = document.createElement("label");
      card.className = `flow-card skill-card ${selected ? "selected" : ""}`;
      card.innerHTML = `<input type="checkbox" ${selected ? "checked" : ""}><h3>${skill}</h3><p>Tap to include this skill in your team.</p>`;
      card.onclick = function(event) {
        event.preventDefault();
        toggleSkill(skill);
      };
      grid.appendChild(card);
    });
  }

  function selectEntry(mode) {
    wizardState.entry = mode;
    wizardState.quoteIndex = 0;
    updateStep4ForRole();
    updateStep5And6Content();
    startQuotes();
    wizardNext();
  }

  function selectCategory(categoryId) {
    wizardState.category = categoryId;
    wizardState.skills = [];
    renderCategoryCards();
    renderSkillCards();
    setWizardError("");
  }

  function toggleSkill(skill) {
    if (wizardState.skills.includes(skill)) {
      wizardState.skills = wizardState.skills.filter(item => item !== skill);
    } else {
      wizardState.skills.push(skill);
    }
    renderSkillCards();
    setWizardError("");
  }

  function wizardNext() {
    if (!validateWizardStep()) return;
    const maxStep = wizardState.entry === "join" ? 6 : 7;
    if (wizardState.step < maxStep) {
      wizardState.step += 1;
      updateWizardStep();
    }
  }

  function wizardPrev() {
    if (wizardState.step > 1) {
      wizardState.step -= 1;
      updateWizardStep();
      setWizardError("");
    }
  }

  function validateWizardStep() {
    if (wizardState.step === 1 && !wizardState.entry) {
      setWizardError("Please choose Create Project or Join Project to continue.");
      return false;
    }
    if (wizardState.step === 2 && !wizardState.category) {
      setWizardError("Select one category.");
      return false;
    }
    if (wizardState.step === 3 && wizardState.skills.length === 0) {
      setWizardError("Choose at least one skill.");
      return false;
    }
    if (wizardState.step === 4) {
      const name = document.getElementById("wizardProjectName").value.trim();
      const desc = document.getElementById("wizardShortDesc").value.trim();
      const teamSize = document.getElementById("wizardTeamSize").value;
      const deadline = document.getElementById("wizardDeadline").value;
      if (wizardState.entry === "join") {
        if (!name || !desc || !deadline) {
          setWizardError("Fill your name, intro, and joining availability.");
          return false;
        }
      } else if (!name || !desc || !teamSize || !deadline) {
        setWizardError("Fill all project details before moving ahead.");
        return false;
      }
    }
    if (wizardState.step === 6 && wizardState.entry === "create") {
      const minSalary = document.getElementById("wizardMinSalary").value;
      const maxSalary = document.getElementById("wizardMaxSalary").value;
      if (!minSalary || !maxSalary || parseInt(minSalary) > parseInt(maxSalary)) {
        setWizardError("Set a valid salary range.");
        return false;
      }
    }
    if (wizardState.step === 5) {
      const vision = document.getElementById("wizardVision").value.trim();
      if (!vision) {
        setWizardError("Share your project vision to complete setup.");
        return false;
      }
    }
    setWizardError("");
    return true;
  }

  function updateWizardStep() {
    const steps = document.querySelectorAll(".flow-step");
    steps.forEach(step => step.classList.remove("active"));
    document.getElementById(`wizardStep${wizardState.step}`).classList.add("active");

    const copy = wizardCopy[wizardState.step - 1];
    const isJoin = wizardState.entry === "join";
    let title = copy.title;
    let subtitle = copy.subtitle;
    if (wizardState.step === 5 && isJoin) {
      title = "Your joining intent";
      subtitle = "Tell teams what value you will bring.";
    }
    if (wizardState.step === 6 && isJoin) {
      title = "Matched projects";
      subtitle = "Open roles tuned to your category, skills, and optional pay expectation.";
    }
    if (wizardState.step === 4 && isJoin) {
      title = "Join preferences";
      subtitle = "Tell us what projects and teams you want to join.";
    }
    document.getElementById("wizardTitle").textContent = title;
    document.getElementById("wizardSubtitle").textContent = subtitle;
    const totalSteps = isJoin ? 6 : 7;
    document.getElementById("wizardProgressFill").style.width = `${(wizardState.step / totalSteps) * 100}%`;

    const budgetPanel = document.getElementById("wizardCreateBudget");
    const joinMatchPanel = document.getElementById("wizardJoinMatches");
    if (budgetPanel && joinMatchPanel) {
      const budgetVisible = wizardState.step === 6 && !isJoin;
      budgetPanel.style.display = budgetVisible ? "" : "none";
      joinMatchPanel.style.display = wizardState.step === 6 && isJoin ? "block" : "none";
      if (wizardState.step === 6 && isJoin) renderJoinWizardMatches();
    }

    const backBtn = document.getElementById("wizardBack");
    backBtn.classList.toggle("show", wizardState.step > 1);

    const nextBtn = document.getElementById("wizardNextBtn");
    const maxStep = isJoin ? 6 : 7;
    if (wizardState.step >= maxStep) {
      nextBtn.style.display = "none";
    } else {
      nextBtn.style.display = "inline-block";
      if (wizardState.step === maxStep - 1 && isJoin) {
        nextBtn.textContent = "View matching projects";
      } else {
        nextBtn.textContent = wizardState.step === maxStep - 1 ? "Complete Setup" : "Next";
      }
    }

    const invitePanel = document.getElementById("inviteMembersPanel");
    if (wizardState.step === 7 && wizardState.entry === "create" && invitePanel && !invitePanel.classList.contains("hidden")) {
      renderInviteSuggestions();
    }
  }

  function updateStep4ForRole() {
    const labels = document.querySelectorAll("#wizardStep4 label");
    const isJoin = wizardState.entry === "join";
    const teamRow = document.getElementById("wizardTeamSizeRow");
    if (teamRow) teamRow.style.display = isJoin ? "none" : "";
    if (labels.length < 5) return;

    labels[0].textContent = isJoin ? "Your Name" : "Project Name";
    labels[1].textContent = isJoin ? "Your Intro / Summary" : "Short Description";
    labels[2].textContent = "Team Size Needed";
    labels[3].textContent = isJoin ? "Joining Availability" : "Deadline";
    labels[4].textContent = isJoin ? "Upload Portfolio / Resume" : "Upload Cover Image";

    document.getElementById("wizardProjectName").placeholder = isJoin ? "Enter your full name" : "Neon Dream Studio Platform";
    document.getElementById("wizardShortDesc").placeholder = isJoin ? "I am a frontend developer looking to contribute to high-impact products." : "Describe your project in one punchy paragraph.";
    document.getElementById("wizardTeamSize").placeholder = isJoin ? "5" : "6";
  }

  function updateStep5And6Content() {
    const isJoin = wizardState.entry === "join";
    const motiveLabel = document.getElementById("wizardMotiveLabel");
    const visionInput = document.getElementById("wizardVision");
    const completeTitle = document.getElementById("wizardCompleteTitle");
    const completeSubtext = document.getElementById("wizardCompleteSubtext");
    const primaryAction = document.getElementById("wizardPrimaryAction");
    const secondaryAction = document.getElementById("wizardSecondaryAction");

    if (isJoin) {
      motiveLabel.textContent = "Why do you want to join this project?";
      visionInput.placeholder = "I want to join this project to contribute my skills, learn from the team, and create meaningful work together.";
      completeTitle.textContent = "You are ready to join.";
      completeSubtext.textContent = "Connect with creators and start collaborating today.";
      primaryAction.textContent = "Explore Projects";
      secondaryAction.textContent = "Complete Profile";
    } else {
      motiveLabel.textContent = "What is your vision for this project?";
      visionInput.placeholder = "We want to create a short sci-fi film that explores dreams and reality.";
      completeTitle.textContent = "Your project is ready.";
      completeSubtext.textContent = "Start building with creators around the world.";
      primaryAction.textContent = "Enter Dashboard";
      secondaryAction.textContent = "Invite people";
    }
  }

  function renderJoinWizardMatches() {
    const list = document.getElementById("joinMatchProjectList");
    if (!list) return;
    const input = document.getElementById("wizardJoinExpectSalary");
    let expectParsed = NaN;
    if (input && input.value.trim()) {
      expectParsed = parseInt(input.value, 10);
    }
    const expectMonthly = Number.isFinite(expectParsed) ? expectParsed : null;
    if (input && !input.dataset.liveBound) {
      input.dataset.liveBound = "1";
      input.addEventListener("input", renderJoinWizardMatches);
    }
    const rows = buildMarketMatches(wizardState.category, wizardState.skills || [], expectMonthly);
    list.innerHTML = "";
    const top = rows.slice(0, 8);
    if (!top.length) {
      list.innerHTML = "<p class=\"flow-subtitle\" style=\"grid-column:1/-1;\">We will personalize projects on your dashboard after you finish.</p>";
      return;
    }
    top.forEach(proj => {
      const card = document.createElement("div");
      card.className = "flow-card";
      card.style.cursor = "default";
      card.innerHTML = `
        <h3>${proj.name}</h3>
        <p>${proj.desc}</p>
        <p style="margin:10px 0 0;font-size:12px;color:#94a3b8;">Budget: ${proj.salaryLabel}</p>
        <p style="font-size:12px;color:#94a3b8;">Roles: ${proj.roles.join(", ")}</p>
        <p style="margin-top:10px;color:#38bdf8;font-weight:700;font-size:13px;">${proj.match}% match</p>
      `;
      list.appendChild(card);
    });
  }

  function setWizardError(message) {
    document.getElementById("wizardError").textContent = message;
  }

  function startQuotes() {
    const quoteRotator = document.getElementById("quoteRotator");
    const selectedQuotes = wizardState.entry === "join" ? joinQuotes : quotes;
    quoteRotator.textContent = selectedQuotes[0];
    if (wizardState.quoteInterval) {
      clearInterval(wizardState.quoteInterval);
    }
    wizardState.quoteInterval = setInterval(() => {
      wizardState.quoteIndex = (wizardState.quoteIndex + 1) % selectedQuotes.length;
      quoteRotator.textContent = selectedQuotes[wizardState.quoteIndex];
    }, 2800);
  }

  function renderParticles() {
    const particles = document.getElementById("wizardParticles");
    particles.innerHTML = "";
    for (let i = 0; i < 28; i += 1) {
      const particle = document.createElement("span");
      particle.className = "particle";
      particle.style.left = `${Math.random() * 100}%`;
      particle.style.animationDelay = `${Math.random() * 6}s`;
      particle.style.animationDuration = `${6 + Math.random() * 4}s`;
      particle.style.opacity = `${0.3 + Math.random() * 0.7}`;
      particles.appendChild(particle);
    }
  }

  function enterDashboard() {
    const projectData = getProjectDataFromWizard();
    if (wizardState.entry === "join") {
      showNotification("Setup saved. Opening your dashboard with matched projects.");
    } else {
      showNotification("Project created successfully. Opening dashboard.");
    }
    // Publish created projects to backend (if server running)
    if (wizardState.entry === "create" && appState.user && appState.user.contact) {
      const payload = {
        ownerContact: appState.user.contact,
        name: projectData.name,
        desc: projectData.description,
        categoryId: projectData.categoryId,
        category: projectData.category,
        roles: projectData.skills || [],
        salaryMin: projectData.salaryMin ? parseInt(projectData.salaryMin, 10) : 0,
        salaryMax: projectData.salaryMax ? parseInt(projectData.salaryMax, 10) : 0,
        currency: projectData.salaryCurrency || "USD"
      };
      if (payload.salaryMin && payload.salaryMax && payload.roles.length && payload.categoryId) {
        fetch("/api/projects/publish", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        }).then(() => apiGetSeed()).catch(() => {});
      }
    }
    activateDashboard(projectData);
    closeProjectModal();
  }

  let invitePanelInputsBound = false;
  let invitePanelRefreshTimer = null;

  function scheduleInviteSuggestionsRefresh() {
    const panel = document.getElementById("inviteMembersPanel");
    if (!panel || panel.classList.contains("hidden")) return;
    clearTimeout(invitePanelRefreshTimer);
    invitePanelRefreshTimer = setTimeout(() => renderInviteSuggestions(), 160);
  }

  function bindInvitePanelLiveInputs() {
    if (invitePanelInputsBound) return;
    invitePanelInputsBound = true;
    ["wizardMinSalary", "wizardMaxSalary", "wizardCurrency", "wizardVision", "wizardShortDesc", "wizardProjectName"].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      el.addEventListener("input", scheduleInviteSuggestionsRefresh);
      el.addEventListener("change", scheduleInviteSuggestionsRefresh);
    });
  }

  function renderInviteSuggestions() {
    const panel = document.getElementById("inviteMembersPanel");
    const heading = document.getElementById("invitePanelHeading");
    const hint = document.getElementById("inviteBudgetHint");
    const contextLine = document.getElementById("inviteContextLine");
    const mount = document.getElementById("invitePeopleList");
    if (!panel || !hint || !mount) return;

    const min = parseInt(document.getElementById("wizardMinSalary").value, 10);
    const max = parseInt(document.getElementById("wizardMaxSalary").value, 10);
    const cur = document.getElementById("wizardCurrency").value;
    const cat = wizardState.category;
    const categoryTitle = wizardCategories.find(c => c.id === cat)?.title || "your category";
    const selectedSkills = wizardState.skills.length ? wizardState.skills.slice() : [];
    const keywords = extractInviteKeywords();
    const projMin = Number.isFinite(min) ? min : NaN;
    const projMax = Number.isFinite(max) ? max : NaN;
    const bandValid = Number.isFinite(projMin) && Number.isFinite(projMax) && projMax >= projMin;

    if (heading) {
      heading.textContent = `People matched to ${categoryTitle}`;
    }

    if (bandValid) {
      hint.textContent = `Ranking uses your budget ${formatSalaryBand(projMin, projMax, cur)}, the roles you selected, your project copy, and this category.`;
    } else {
      hint.textContent = "Add a min and max salary on the previous step to prioritize creators who fit your budget band.";
    }

    if (contextLine) {
      const skillLine = selectedSkills.length
        ? `Roles you asked for: ${selectedSkills.join(", ")}.`
        : "Pick skills earlier in the flow for tighter matches.";
      const keyLine = keywords.length ? ` Keywords from your pitch: ${keywords.slice(0, 8).join(", ")}${keywords.length > 8 ? "…" : ""}.` : "";
      contextLine.textContent = skillLine + keyLine;
    }

    const ctx = {
      categoryId: cat,
      selectedSkills,
      keywords,
      projMin: bandValid ? projMin : NaN,
      projMax: bandValid ? projMax : NaN
    };

    const scored = MOCK_INVITE_CREATORS.map(person => {
      const { exact, partial } = skillAlignmentForInvite(selectedSkills, person);
      const matchPct = scoreInvitePerson(person, ctx);
      const budgetOverlap = bandValid ? budgetBandOverlapScore(projMin, projMax, person.rateMin, person.rateMax) : null;
      const lo = Math.max(projMin, person.rateMin);
      const hi = Math.min(projMax, person.rateMax);
      const overlaps = bandValid && hi >= lo;
      return { person, exact, partial, matchPct, budgetOverlap, overlaps };
    }).sort((a, b) => b.matchPct - a.matchPct);

    mount.innerHTML = "";
    const top = scored.slice(0, 12);
    top.forEach(({ person, exact, partial, matchPct, overlaps }) => {
      const row = document.createElement("div");
      row.className = "suggestion-card";
      const skillNote = exact
        ? `${exact} exact role match${exact > 1 ? "es" : ""}${partial ? ` · ${partial} partial` : ""}`
        : partial
          ? `${partial} partial skill match${partial > 1 ? "es" : ""}`
          : "Broad fit — refine skills on step 3 for sharper results";
      const budgetNote = !bandValid
        ? "Set a salary band to score budget fit."
        : overlaps
          ? "Inside your budget band."
          : "Outside your min–max band; still listed if strong on skills or pitch keywords.";
      const pillClass = matchPct >= 52 ? "invite-match-pill" : "invite-match-pill loose";
      row.innerHTML = `
        <div style="flex:1;min-width:0;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;">
            <strong>${person.name}</strong>
            <div class="invite-match-row"><span class="${pillClass}">${matchPct}% fit</span></div>
          </div>
          <div class="suggestion-meta">${person.tagline}</div>
          <div class="suggestion-meta">${person.skills.join(" · ")}</div>
          <div class="suggestion-meta">Typical band: ${formatSalaryBand(person.rateMin, person.rateMax, person.currency)}</div>
          <div class="suggestion-meta">${skillNote} · ${budgetNote}</div>
        </div>
        <button type="button" class="dashboard-pill-btn" data-invite-id="${person.id}">Invite</button>
      `;
      row.querySelector("[data-invite-id]").addEventListener("click", ev => {
        const id = ev.currentTarget.getAttribute("data-invite-id");
        const p = MOCK_INVITE_CREATORS.find(x => x.id === id);
        const name = p ? p.name : "Creator";
        showNotification(`Invite drafted for ${name} (${matchPct}% fit for your inputs).`);
        const fromContact = (appState.user && appState.user.contact) ? appState.user.contact : "";
        const projectName = document.getElementById("wizardProjectName")?.value || "";
        if (fromContact) {
          fetch("/api/invites", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ fromContact, toPersonId: id, projectName })
          }).catch(() => {});
        }
      });
      mount.appendChild(row);
    });
  }

  function inviteMembers() {
    if (wizardState.entry === "join") {
      showNotification("Finish your onboarding from the Projects tab.");
      return;
    }
    const panel = document.getElementById("inviteMembersPanel");
    if (!panel) return;
    bindInvitePanelLiveInputs();
    panel.classList.toggle("hidden");
    if (!panel.classList.contains("hidden")) {
      renderInviteSuggestions();
    }
  }

  /* =======================
     DASHBOARD CORE
  ======================= */
  const dashboardState = {
    creator: {
      activeNav: "Dashboard",
      tasks: {
        todo: ["Finalize concept deck", "Define onboarding flow"],
        inProgress: ["Create teaser content"],
        completed: ["Team kickoff call"]
      },
      chat: ["Arjun: Welcome everyone!", "Maya: I can take UI screens."],
      activity: ["New file uploaded: project-plan.pdf", "Task moved to In Progress"],
      joinRequests: [
        { id: "j1", name: "Rohan - Video Editor" },
        { id: "j2", name: "Anika - Frontend Developer" }
      ],
      notifications: ["2 new comments on tasks", "1 join request pending"]
    }
  };

  let dashboardDomCache = null;

  function getProjectDataFromWizard() {
    const categoryObj = wizardCategories.find(item => item.id === wizardState.category);
    const mode = wizardState.entry === "join" ? "Joined Project" : "Created Project";
    const enteredName = document.getElementById("wizardProjectName").value.trim();
    const shortDesc = document.getElementById("wizardShortDesc").value.trim();
    const joinProjectName = `${categoryObj ? categoryObj.title : "General"} Collaboration`;
    const joinExpectEl = document.getElementById("wizardJoinExpectSalary");
    let joinExpectSalary = "";
    if (joinExpectEl && joinExpectEl.value.trim()) joinExpectSalary = joinExpectEl.value.trim();
    const minSal = document.getElementById("wizardMinSalary") ? document.getElementById("wizardMinSalary").value : "";
    const maxSal = document.getElementById("wizardMaxSalary") ? document.getElementById("wizardMaxSalary").value : "";
    const cur = document.getElementById("wizardCurrency") ? document.getElementById("wizardCurrency").value : "USD";

    const teamRaw = document.getElementById("wizardTeamSize") ? document.getElementById("wizardTeamSize").value : "";

    return {
      mode,
      memberName: wizardState.entry === "join" ? enteredName : "",
      name: wizardState.entry === "join" ? (joinProjectName || "Collaboration Opportunity") : (enteredName || "Untitled Project"),
      description: shortDesc || "No description provided yet.",
      category: categoryObj ? categoryObj.title : "General",
      categoryId: wizardState.category,
      skills: wizardState.skills.length ? wizardState.skills.slice() : ["Collaboration"],
      teamSize: wizardState.entry === "join" ? "Self" : (teamRaw || "N/A"),
      deadline: document.getElementById("wizardDeadline").value || "Flexible",
      vision: document.getElementById("wizardVision").value.trim() || "Vision to be updated.",
      joinExpectSalary,
      salaryMin: minSal,
      salaryMax: maxSal,
      salaryCurrency: cur
    };
  }

  function activateDashboard(projectData) {
    appState.currentProject = projectData;
    try {
      localStorage.setItem("makeBigActiveProject", JSON.stringify(projectData));
    } catch (e) {}
    appState.role = wizardState.entry === "join" ? "member" : "creator";
    appState.view = appState.role === "member" ? "social_dashboard" : "dashboard";
    if (appState.role === "member") {
      initializeMemberState(projectData);
    }
    renderApp();
  }

  function initializeMemberState(projectData) {
    const createAiImage = (title, c1, c2) => {
      const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='1200' height='700'><defs><linearGradient id='g' x1='0' x2='1' y1='0' y2='1'><stop stop-color='${c1}'/><stop offset='1' stop-color='${c2}'/></linearGradient></defs><rect width='1200' height='700' fill='url(#g)'/><circle cx='220' cy='180' r='140' fill='rgba(255,255,255,0.16)'/><circle cx='960' cy='520' r='180' fill='rgba(255,255,255,0.12)'/><text x='80' y='370' fill='white' font-size='58' font-family='Arial' font-weight='700'>${title}</text></svg>`;
      return `data:image/svg+xml;utf8,${encodeURIComponent(svg)}`;
    };

    if (appState.posts.length === 0) {
      appState.posts = [
        {
          id: "post1",
          avatar: "NT",
          name: "Nova Team",
          timestamp: "2h ago",
          text: "Sprint update: authentication flow completed.",
          likes: 12,
          liked: false,
          comments: ["Great progress!", "Can I contribute to UI?"],
          imageTitle: "AI Sprint Board",
          imageDesc: "Realtime sprint visibility powered by AI insights.",
          imageUrl: createAiImage("AI Sprint Board", "#1d4ed8", "#0ea5e9")
        },
        {
          id: "post2",
          avatar: "AS",
          name: "Asha",
          timestamp: "5h ago",
          text: "Looking for collaborators for AI short film project.",
          likes: 8,
          liked: false,
          comments: ["Interested!", "Sent connection request."],
          imageTitle: "Neural Cinema Concept",
          imageDesc: "Generative scene boards for a collaborative sci-fi short.",
          imageUrl: createAiImage("Neural Cinema", "#7c3aed", "#2563eb")
        },
        {
          id: "post3",
          avatar: "RJ",
          name: "Ria Jain",
          timestamp: "8h ago",
          text: "We just completed user interviews for the creator dashboard.",
          likes: 14,
          liked: false,
          comments: ["Can you share highlights?"]
        },
        {
          id: "post4",
          avatar: "KM",
          name: "Karan M",
          timestamp: "1d ago",
          text: "Our cross-team collab boosted project velocity by 23%.",
          likes: 21,
          liked: false,
          comments: ["Amazing result!", "Need this workflow doc."]
        },
        {
          id: "post5",
          avatar: "ML",
          name: "Mia Lee",
          timestamp: "1d ago",
          text: "Published the first interactive prototype for feedback.",
          likes: 17,
          liked: false,
          comments: ["Looks clean.", "Will test tonight."]
        }
      ];
    }

    if (appState.people.length === 0) {
      appState.people = [
        { id: "u1", name: "Nisha Rao", skills: "UI/UX, Figma", bio: "Designs clean, conversion-focused user journeys.", connected: false, avatar: "NR", activeProjects: ["Future Frames", "Creator OS"] },
        { id: "u2", name: "Kabir Jain", skills: "Backend, Node.js", bio: "Builds scalable APIs and realtime systems.", connected: true, avatar: "KJ", activeProjects: ["AI Podcast Suite"] },
        { id: "u3", name: "Mia George", skills: "Content Strategy", bio: "Turns ideas into viral content formats.", connected: false, avatar: "MG", activeProjects: ["Growth Content Sprint"] }
      ];
    }

    if (appState.notifications.length === 0) {
      appState.notifications = [
        "Connection request from Nisha Rao",
        "Task update in AI Podcast Suite",
        "Your post got 8 likes",
        "New comment on your progress update"
      ];
    }

    appState.recommendations = buildRecommendations(projectData);
    const derivedProjects = appState.recommendations.map(reco => ({
      id: `mp-${reco.id}`,
      name: reco.name,
      category: reco.category,
      status: `${reco.match}% fit`,
      progress: Math.min(92, Math.max(38, Math.round(Number(reco.match) * 0.9))),
      description: `${reco.desc} Roles: ${reco.roles.join(", ")}${reco.salaryLabel ? ` · ${reco.salaryLabel}` : ""}`
    }));
    if (derivedProjects.length) {
      appState.projects = derivedProjects;
    } else if (appState.projects.length === 0) {
      appState.projects = [
        {
          id: "p-placeholder",
          name: `${projectData.category} opportunities`,
          category: projectData.category,
          status: "New matches soon",
          progress: 40,
          description: "Adjust your filters in Explore to widen matches."
        }
      ];
    }
    appState.activeTab = wizardState.entry === "join" ? "projects" : "home";
  }

  function buildRecommendations(projectData) {
    const catId = projectData.categoryId || wizardCategories.find(c => c.title === projectData.category)?.id || "web";
    const expectMonthly = projectData.joinExpectSalary ? parseInt(projectData.joinExpectSalary, 10) : NaN;
    const expect = Number.isFinite(expectMonthly) ? expectMonthly : null;
    let rows = buildMarketMatches(catId, projectData.skills || [], expect);
    rows = rows.map(row => ({
      id: row.id,
      name: row.name,
      category: row.category,
      desc: row.desc,
      roles: row.roles,
      match: row.match,
      salaryLabel: row.salaryLabel
    }));
    if (!rows.length) {
      rows = buildMarketMatches("web", projectData.skills || [], expect).map(row => ({
        id: row.id,
        name: row.name,
        category: row.category,
        desc: row.desc,
        roles: row.roles,
        match: row.match,
        salaryLabel: row.salaryLabel
      }));
    }
    return rows.slice(0, 8);
  }

  function renderApp() {
    const homeSections = [
      document.querySelector(".navbar"),
      document.querySelector(".hero"),
      document.querySelector(".skills"),
      document.querySelector(".footer")
    ];
    const dashboardRoot = document.getElementById("dashboardRoot");

    if (appState.view === "dashboard" || appState.view === "social_dashboard") {
      homeSections.forEach(section => {
        if (section) section.style.display = "none";
      });
      dashboardRoot.classList.add("active");
      renderDashboard();
      document.body.style.overflow = "auto";
      return;
    }

    dashboardRoot.classList.remove("active");
    homeSections.forEach(section => {
      if (section) section.style.display = "";
    });
  }

  function renderDashboard() {
    const root = document.getElementById("dashboardRoot");
    if (!dashboardDomCache) {
      dashboardDomCache = {};
    }
    if (appState.role === "member") {
      renderMemberDashboard(root);
      return;
    }
    renderCreatorDashboard(root);
  }

  /* =======================
     DASHBOARD COMPONENTS
  ======================= */
  function createTopBar(options = {}) {
    const { searchPlaceholder = "Search tasks, members, files...", onNotification, inviteLabel = "Invite Member", onInvite } = options;
    const topBar = document.createElement("header");
    topBar.className = "dashboard-topbar";
    topBar.innerHTML = `
      <h3 id="dashboardProjectName">Project Dashboard</h3>
      <div class="topbar-search"><input id="dashboardSearch" type="text" placeholder="${searchPlaceholder}"></div>
      <div class="dashboard-top-actions">
        <button id="dashboardNotifBtn" class="dashboard-pill-btn">Notifications</button>
        <button id="dashboardInviteBtn" class="dashboard-pill-btn">${inviteLabel}</button>
        <button id="dashboardProfileBtn" class="dashboard-pill-btn">Profile</button>
      </div>
    `;
    topBar.querySelector("#dashboardNotifBtn").addEventListener("click", onNotification || (() => showNotification("You have 3 unread updates.")));
    topBar.querySelector("#dashboardInviteBtn").addEventListener("click", onInvite || handleInviteMember);
    topBar.querySelector("#dashboardProfileBtn").addEventListener("click", () => renderProfileDropdown());
    return topBar;
  }

  function createSidebar(items, activeKey, handler) {
    const sidebar = document.createElement("aside");
    sidebar.className = "dashboard-sidebar";
    sidebar.innerHTML = `<div id="dashboardNav" class="dashboard-nav"></div>`;
    const nav = sidebar.querySelector("#dashboardNav");
    items.forEach(item => {
      const button = document.createElement("button");
      button.type = "button";
      button.textContent = item;
      button.dataset.nav = item;
      if (item === activeKey) button.classList.add("active");
      button.addEventListener("click", handler);
      nav.appendChild(button);
    });
    return sidebar;
  }

  function createOverviewSection() {
    const project = appState.currentProject || {};
    const completedTasks = JSON.parse(localStorage.getItem('completedTasks') || '[]');
    const todoTasks = JSON.parse(localStorage.getItem('todoTasks') || '[]');
    const inProgressTasks = JSON.parse(localStorage.getItem('inProgressTasks') || '[]');
    const totalTasks = completedTasks.length + todoTasks.length + inProgressTasks.length;
    const progress = totalTasks > 0 ? Math.round((completedTasks.length / totalTasks) * 100) : 0;
    
    const section = document.createElement("section");
    section.className = "dashboard-card";
    section.innerHTML = `
      <h4>Project Overview</h4>
      <div class="dashboard-row"><span>${project.category || "General"}</span><span>${project.mode || "Active"}</span></div>
      <p style="margin:0 0 10px;color:#cbd5e1;">${project.description || "No description available."}</p>
      <div class="progress-track"><div class="progress-fill" style="width:${progress}%"></div></div>
      <p style="margin:8px 0 0;color:#94a3b8;font-size:13px;">Progress: ${progress}% (${completedTasks.length}/${totalTasks} tasks) | Deadline: ${project.deadline || "Flexible"}</p>
    `;
    return section;
  }

  function createTeamSection() {
    const project = appState.currentProject || {};
    const section = document.createElement("section");
    section.className = "dashboard-card";
    const teamMembers = JSON.parse(localStorage.getItem('teamMembers') || '[]');
    const userDisplayName = appState.user ? appState.user.name : "Creator";
    
    const membersList = [
      { name: userDisplayName, role: "Project Lead" },
      ...teamMembers.map(m => ({ name: m.name, role: m.role }))
    ];
    
    const chips = membersList.map(m => `<div class="tag-chip">${m.name} - ${m.role}</div>`).join("");
    
    section.innerHTML = `
      <h4>Team Members (${membersList.length})</h4>
      <div class="mini-grid">
        ${chips || '<div class="tag-chip">Just you for now</div>'}
      </div>
      <p style="margin:10px 0 0;color:#94a3b8;font-size:13px;">Team size needed: ${project.teamSize || "N/A"}</p>
      <button class="dashboard-pill-btn" id="addTeamMemberBtn" style="margin-top: 10px; width: 100%;">Add Team Member</button>
    `;
    
    section.querySelector("#addTeamMemberBtn").addEventListener("click", handleAddTeamMember);
    return section;
  }

  function handleAddTeamMember() {
    const modal = document.createElement("div");
    modal.className = "modal active";
    modal.innerHTML = `
      <div class="modal-overlay"></div>
      <div class="modal-content" style="max-width: 440px;">
        <button class="modal-close" type="button">✕</button>
        <h2 class="modal-title">Add Team Member</h2>
        <p class="modal-subtitle">Invite or add a team member to your project</p>
        <form id="addTeamForm">
          <div class="form-group">
            <label for="memberName">Team Member Name</label>
            <input type="text" id="memberName" placeholder="Enter name" required>
          </div>
          <div class="form-group">
            <label for="memberRole">Role / Position</label>
            <input type="text" id="memberRole" placeholder="e.g. Frontend Developer, Designer" required>
          </div>
          <div class="form-group">
            <label for="memberContact">Email or Phone (optional)</label>
            <input type="text" id="memberContact" placeholder="Contact info">
          </div>
          <button type="submit" class="submit-btn">Add Member</button>
          <button type="button" class="cancel-btn" onclick="this.closest('.modal').remove()">Cancel</button>
        </form>
      </div>
    `;
    document.body.appendChild(modal);
    
    modal.querySelector(".modal-overlay").addEventListener("click", () => modal.remove());
    modal.querySelector(".modal-close").addEventListener("click", () => modal.remove());
    
    modal.querySelector("#addTeamForm").addEventListener("submit", (e) => {
      e.preventDefault();
      const name = document.getElementById("memberName").value;
      const role = document.getElementById("memberRole").value;
      const contact = document.getElementById("memberContact").value;
      
      const teamMembers = JSON.parse(localStorage.getItem('teamMembers') || '[]');
      teamMembers.push({ name, role, contact, addedAt: new Date().toISOString() });
      localStorage.setItem('teamMembers', JSON.stringify(teamMembers));
      
      showNotification(`${name} added as ${role}`);
      modal.remove();
      renderCreatorMainSections(document.querySelector(".dashboard-main"));
    });
  }

  function createWhoYouNeedSection() {
    const project = appState.currentProject || {};
    const section = document.createElement("section");
    section.className = "dashboard-card";
    const chips = (project.skills || []).map(skill => `<div class="tag-chip">${skill}</div>`).join("");
    section.innerHTML = `<h4>Who You Need</h4><div class="mini-grid">${chips || '<div class="tag-chip">No skills selected</div>'}</div>`;
    return section;
  }

