          <div style="color: #94a3b8; font-size: 12px; margin-top: 4px;">Public</div>
        </div>
        <div style="padding: 12px; border: 1px solid rgba(148,163,184,0.2); border-radius: 8px;">
          <div style="color: #cbd5e1; font-size: 13px; font-weight: 600;">Project Status</div>
          <div style="color: #94a3b8; font-size: 12px; margin-top: 4px;">Active</div>
        </div>
        <button class="dashboard-pill-btn" style="width: 100%;">Edit Settings</button>
      </div>
    `;
