  function createActivitySection() {
    const section = document.createElement("section");
    section.className = "dashboard-card";
    section.innerHTML = `<h4>Activity Feed</h4><div id="activityFeed"></div>`;
    return section;
  }

  function createJoinRequestSection() {
    const section = document.createElement("section");
    section.className = "dashboard-card";
    section.innerHTML = `<h4>Join Requests</h4><div id="joinRequests"></div>`;
    return section;
  }

  function createNotificationsSection() {
    const section = document.createElement("section");
    section.className = "dashboard-card";
    const notifications = JSON.parse(localStorage.getItem('projectNotifications') || '[]');
    section.innerHTML = `
      <h4>Notifications</h4>
      <div id="notificationsList"></div>
    `;
    const list = section.querySelector("#notificationsList");
    if (notifications.length === 0) {
      const emptyEl = document.createElement("p");
      emptyEl.style.color = "#94a3b8";
      emptyEl.style.fontSize = "13px";
      emptyEl.textContent = "No new notifications";
      list.appendChild(emptyEl);
    } else {
      notifications.forEach((notif, idx) => {
        const row = document.createElement("div");
        row.className = "dashboard-row";
        row.style.paddingBottom = "8px";
        row.style.borderBottom = "1px solid rgba(148,163,184,0.2)";
        row.style.marginBottom = "8px";
        row.innerHTML = `
          <span style="font-size:13px;color:#cbd5e1;">${notif}</span>
          <button class="dashboard-pill-btn" data-notif-idx="${idx}" style="font-size: 11px; padding: 4px 8px;">Dismiss</button>
        `;
        row.querySelector("button").addEventListener("click", (e) => {
          const idx = parseInt(e.currentTarget.dataset.notifIdx);
          const notifs = JSON.parse(localStorage.getItem('projectNotifications') || '[]');
          notifs.splice(idx, 1);
          localStorage.setItem('projectNotifications', JSON.stringify(notifs));
          hydrateCreatorRightPanel();
        });
        list.appendChild(row);
      });
    }
    return section;
  }

  function createTrendingSection() {
    const section = document.createElement("section");
    section.className = "dashboard-card";
    section.innerHTML = `<h4>Trending Creators</h4><div id="trendingCreators"></div>`;
    return section;
  }

  function createSalaryTrackingSection() {
    const section = document.createElement("section");
    section.className = "dashboard-card";
    const project = appState.currentProject || {};
    const salaryMin = parseInt(project.salaryMin) || 0;
    const salaryMax = parseInt(project.salaryMax) || 0;
    const avgSalary = salaryMin && salaryMax ? Math.round((salaryMin + salaryMax) / 2) : 0;
    const currency = project.salaryCurrency || "USD";
    
    // Get salary data from localStorage or default
    const salaryData = JSON.parse(localStorage.getItem('userSalaryData') || '{"given": 0, "pending": 0, "currency": "' + currency + '"}');
    const totalGiven = salaryData.given || 0;
    const pending = salaryData.pending || 0;
    
    section.innerHTML = `
      <h4>💰 Salary & Compensation Tracker</h4>
      <div class="dashboard-row" style="margin-bottom: 12px;">
        <span style="color: #cbd5e1;">Budget Range:</span>
        <span style="color: #7dd3fc; font-weight: 600;">${currency} ${salaryMin.toLocaleString()} - ${salaryMax.toLocaleString()} / month</span>
      </div>
      <div class="dashboard-row" style="margin-bottom: 12px;">
        <span style="color: #cbd5e1;">Total Allocated:</span>
        <span style="color: #38bdf8; font-weight: 600;">${currency} ${totalGiven.toLocaleString()}</span>
      </div>
      <div class="dashboard-row" style="margin-bottom: 12px;">
        <span style="color: #cbd5e1;">Pending/Remaining:</span>
        <span style="color: #f59e0b; font-weight: 600;">${currency} ${pending.toLocaleString()}</span>
      </div>
      <div class="progress-track" style="margin-bottom: 8px;">
        <div class="progress-fill" style="width: ${avgSalary > 0 ? Math.min(100, (totalGiven / avgSalary) * 100) : 0}%; background: linear-gradient(90deg, #f59e0b, #ec4899);"></div>
      </div>
      <p style="margin: 0; color: #94a3b8; font-size: 13px;">
        ${avgSalary > 0 ? `${Math.round((totalGiven / avgSalary) * 100)}% of monthly budget allocated` : 'Set budget range on project creation'}
      </p>
      <div style="margin-top: 12px; display: flex; gap: 8px;">
        <button class="dashboard-pill-btn" id="addSalaryBtn" style="flex: 1;">Add Payment</button>
        <button class="dashboard-pill-btn" id="viewSalaryHistoryBtn" style="flex: 1;">History</button>
      </div>
    `;
    
    section.querySelector("#addSalaryBtn").addEventListener("click", handleAddSalary);
    section.querySelector("#viewSalaryHistoryBtn").addEventListener("click", handleViewSalaryHistory);
    return section;
  }

  function renderCreatorMainSections(main) {
    main.innerHTML = "";
    main.appendChild(createOverviewSection());
    main.appendChild(createWhoYouNeedSection());
    main.appendChild(createTeamSection());
    main.appendChild(createTaskBoard());
    main.appendChild(createChatSection());
    main.appendChild(createFeedSection());
    main.appendChild(createFilesSection());
    hydrateTaskColumns();
    hydrateChat();
    hydrateFeed();
  }

  function createRightPanel() {
    const fragment = document.createDocumentFragment();
    fragment.appendChild(createActivitySection());
    fragment.appendChild(createJoinRequestSection());
    fragment.appendChild(createNotificationsSection());
    return fragment;
  }

  function renderCreatorRightSections(right) {
    right.innerHTML = "";
    right.appendChild(createRightPanel());
    hydrateCreatorRightPanel();
  }

  function hydrateTaskColumns() {
    const addTasks = (containerId, items) => {
      const container = document.getElementById(containerId);
      container.innerHTML = "";
      if (items.length === 0) {
        const empty = document.createElement("div");
        empty.style.color = "#94a3b8";
        empty.style.fontSize = "12px";
        empty.textContent = "No tasks";
        container.appendChild(empty);
      } else {
        items.forEach(item => {
          const el = document.createElement("div");
          el.className = "task-item";
          el.textContent = item;
          container.appendChild(el);
        });
      }
    };
    
    const todoTasks = JSON.parse(localStorage.getItem('todoTasks') || '[]');
    const inProgressTasks = JSON.parse(localStorage.getItem('inProgressTasks') || '[]');
    const completedTasks = JSON.parse(localStorage.getItem('completedTasks') || '[]');
    
    addTasks("todoTasks", todoTasks);
    addTasks("inProgressTasks", inProgressTasks);
    addTasks("completedTasks", completedTasks);
  }

  function hydrateChat() {
    const log = document.getElementById("chatLog");
    log.innerHTML = "";
    const messages = JSON.parse(localStorage.getItem('projectChat') || '[]');
    if (messages.length === 0) {
      const emptyMsg = document.createElement("div");
      emptyMsg.style.color = "#94a3b8";
      emptyMsg.style.fontSize = "13px";
      emptyMsg.textContent = "No messages yet. Start a conversation!";
      log.appendChild(emptyMsg);
    } else {
      messages.forEach(message => {
        const msg = document.createElement("div");
        msg.className = "chat-msg";
        msg.textContent = message;
        log.appendChild(msg);
      });
    }
  }

  function hydrateFeed() {
    const list = document.getElementById("projectFeedList");
    if (!list) return;
    list.innerHTML = "";
    const activities = JSON.parse(localStorage.getItem('projectActivity') || '[]');
    if (activities.length === 0) {
      const emptyItem = document.createElement("div");
      emptyItem.style.color = "#94a3b8";
      emptyItem.style.fontSize = "13px";
      emptyItem.textContent = "Project activity will appear here.";
      list.appendChild(emptyItem);
    } else {
      activities.forEach(item => {
        const row = document.createElement("div");
        row.className = "tag-chip";
        row.style.marginBottom = "6px";
        row.textContent = item;
        list.appendChild(row);
      });
    }
  }

  function hydrateMemberFeed() {
    const list = document.getElementById("memberFeedList");
    if (!list) return;
    list.innerHTML = "";
    appState.posts.forEach(post => {
      const row = document.createElement("div");
      row.className = "feed-post";
      row.innerHTML = `
        <div class="feed-post-head">
          <div class="feed-author">
            <span class="feed-avatar">${post.avatar}</span>
            <div>
              <div style="color:#e2e8f0;font-size:13px;">${post.name}</div>
              <div style="color:#94a3b8;font-size:11px;">${post.timestamp}</div>
            </div>
          </div>
          <span style="color:#94a3b8;font-size:11px;">${post.likes} likes</span>
        </div>
        <p style="margin:0;color:#cbd5e1;">${post.text}</p>
        <div class="feed-actions">
          <button class="dashboard-pill-btn" data-post-id="${post.id}">${post.liked ? "Liked" : "Like"}</button>
          <button class="dashboard-pill-btn">Comment</button>
        </div>
        <div class="post-comments">${post.comments.map(comment => `<div class="post-comment-item">${comment}</div>`).join("")}</div>
      `;
      row.querySelector("[data-post-id]").addEventListener("click", handleLikeToggle);
      list.appendChild(row);
    });
  }

  function renderRecommendations() {
    const container = document.getElementById("recommendationList");
    if (!container) return;
    container.innerHTML = "";
    appState.recommendations.forEach(project => {
      const card = document.createElement("div");
      card.className = "recommend-card";
      const salaryLine = project.salaryLabel ? `<p style="margin:0 0 8px;color:#94a3b8;font-size:12px;">${project.salaryLabel}</p>` : "";
      card.innerHTML = `
        <div class="dashboard-row" style="margin-bottom:6px;">
          <strong style="color:#e2e8f0;">${project.name}</strong>
          <span style="color:#38bdf8;font-size:12px;">${project.match}% match</span>
        </div>
        <p style="margin:0 0 6px;color:#94a3b8;font-size:12px;">${project.category}</p>
        <p style="margin:0 0 8px;color:#cbd5e1;font-size:12px;">${project.desc}</p>
        ${salaryLine}
        <p style="margin:0 0 8px;color:#94a3b8;font-size:12px;">Roles: ${project.roles.join(", ")}</p>
        <button class="dashboard-pill-btn" data-reco-id="${project.id}">Join</button>
      `;
      card.querySelector("[data-reco-id]").addEventListener("click", () => showNotification(`Join request sent for ${project.name}`));
      container.appendChild(card);
    });
  }

  function hydrateActiveProjectFromStorage() {
    try {
      const raw = localStorage.getItem("makeBigActiveProject");
      if (!raw) return;
      const parsed = JSON.parse(raw);
      if (parsed && parsed.name) appState.currentProject = parsed;
      if (parsed && parsed.mode === "Joined Project") appState.role = "member";
      else if (parsed && parsed.mode === "Created Project") appState.role = "creator";
    } catch (e) {}
  }

  function handleNavbarProjectsNav(event) {
    event.preventDefault();
    if (!checkAuth()) {
      openAuth();
      setAuthMessage("Login to view your projects.");
      return;
    }
    hydrateActiveProjectFromStorage();
    if (!appState.currentProject || !localStorage.getItem("user")) {
      showNotification("You have not created or joined a project yet. Tap “Start a Project”.");
      return;
    }
    appState.view = appState.role === "member" ? "social_dashboard" : "dashboard";
    if (appState.role === "member") {
      appState.activeTab = "projects";
    }
    renderApp();
    showNotification("Opened your Projects workspace.");
  }

  function hydrateCreatorRightPanel() {
    const activity = document.getElementById("activityFeed");
    const activities = JSON.parse(localStorage.getItem('projectActivity') || '[]');
    activity.innerHTML = activities.length ?
      activities.map(item => `<div class="tag-chip" style="margin-bottom:6px;">${item}</div>`).join("")
      : '<p style="color:#94a3b8;font-size:13px;">No activity yet</p>';

    const joins = document.getElementById("joinRequests");
    const joinRequests = JSON.parse(localStorage.getItem('joinRequests') || '[]');
    joins.innerHTML = "";
    if (joinRequests.length === 0) {
      const emptyEl = document.createElement("p");
      emptyEl.style.color = "#94a3b8";
      emptyEl.style.fontSize = "13px";
      emptyEl.textContent = "No join requests";
      joins.appendChild(emptyEl);
    } else {
      joinRequests.forEach((req, idx) => {
        const row = document.createElement("div");
        row.className = "dashboard-row";
        row.innerHTML = `
          <span style="font-size:13px;color:#cbd5e1;">${req.name} - ${req.role}</span>
          <div style="display:flex;gap:6px;">
            <button class="dashboard-pill-btn" data-join-idx="${idx}" data-action="approve">Approve</button>
            <button class="dashboard-pill-btn" data-join-idx="${idx}" data-action="reject">Reject</button>
          </div>
        `;
        row.querySelectorAll("button").forEach(btn => btn.addEventListener("click", (e) => {
          const idx = e.currentTarget.dataset.joinIdx;
          const action = e.currentTarget.dataset.action;
          const joinRequests = JSON.parse(localStorage.getItem('joinRequests') || '[]');
          joinRequests.splice(parseInt(idx), 1);
          localStorage.setItem('joinRequests', JSON.stringify(joinRequests));
          hydrateCreatorRightPanel();
          showNotification(`Join request ${action}d.`);
        }));
        joins.appendChild(row);
      });
    }

    const notifs = document.getElementById("notificationsList");
    if (notifs) {
      const notifications = JSON.parse(localStorage.getItem('projectNotifications') || '[]');
      notifs.innerHTML = notifications.length ?
        notifications.map(item => `<div class="tag-chip" style="margin-bottom:6px;">${item}</div>`).join("")
        : '<p style="color:#94a3b8;font-size:13px;">No notifications</p>';
    }
  }

  function updateTopBarProjectName() {
    const title = document.getElementById("dashboardProjectName");
    if (!title || !appState.currentProject) return;
    title.textContent = appState.currentProject.name || "Project Dashboard";
  }

  function updateSidebarSelection(activeNav) {
    const buttons = document.querySelectorAll("#dashboardNav button");
    buttons.forEach(btn => btn.classList.toggle("active", btn.dataset.nav === activeNav));
  }

  /* =======================
     DASHBOARD EVENTS
  ======================= */
  function handleCreatorSidebarNavigation(event) {
    dashboardState.creator.activeNav = event.currentTarget.dataset.nav;
    updateSidebarSelection(dashboardState.creator.activeNav);
    
    const main = document.querySelector(".dashboard-main");
    if (!main) return;
    main.innerHTML = "";
    
    // Handle navigation for all tabs
    switch(dashboardState.creator.activeNav) {
      case "Dashboard":
        main.appendChild(createOverviewSection());
        main.appendChild(createWhoYouNeedSection());
        main.appendChild(createTeamSection());
        main.appendChild(createTaskBoard());
        main.appendChild(createChatSection());
        hydrateTaskColumns();
        hydrateChat();
        break;
      case "Projects":
        main.appendChild(createProjectsListSection());
        break;
      case "Team":
        main.appendChild(createTeamSection());
        break;
      case "Chat":
        main.appendChild(createChatSection());
        hydrateChat();
        break;
      case "Tasks":
        main.appendChild(createTaskBoard());
        hydrateTaskColumns();
        break;
      case "Salary":
        main.appendChild(createSalaryTrackingSection());
        main.appendChild(createSalaryHistorySection());
        break;
      case "Files":
        main.appendChild(createFilesSection());
        break;
      case "Feed":
        main.appendChild(createFeedSection());
        hydrateFeed();
        break;
      case "Meetings":
        main.appendChild(createMeetingsSection());
        break;
      case "Settings":
        main.appendChild(createSettingsSection());
        break;
      default:
        main.appendChild(createOverviewSection());
    }
    
    showNotification(`${dashboardState.creator.activeNav} view selected.`);
  }

  function createSalaryHistorySection() {
    const section = document.createElement("section");
    section.className = "dashboard-card";
    const history = JSON.parse(localStorage.getItem('salaryHistory') || '[]');
    
    section.innerHTML = `
      <h4>Payment History</h4>
      <div style="max-height: 400px; overflow-y: auto;">
        ${history.length ? 
          history.map((entry, idx) => `
            <div class="dashboard-row" style="padding: 8px; border: 1px solid rgba(148,163,184,0.2); border-radius: 8px; margin-bottom: 8px;">
              <div>
                <div style="color: #cbd5e1;">${entry.name || 'Team Member'}</div>
                <div style="color: #94a3b8; font-size: 12px;">${entry.date}</div>
              </div>
              <div style="text-align: right;">
                <div style="color: #38bdf8; font-weight: 600;">${entry.currency} ${entry.amount.toLocaleString()}</div>
                <div style="color: #94a3b8; font-size: 12px;">${entry.type}</div>
              </div>
            </div>
          `).join('')
          : '<p style="color: #94a3b8;">No payment history yet.</p>'
        }
      </div>
    `;
    return section;
  }

  function handleAddSalary() {
    const modal = document.createElement("div");
    modal.className = "modal active";
    modal.innerHTML = `
      <div class="modal-overlay"></div>
      <div class="modal-content" style="max-width: 440px;">
        <button class="modal-close" type="button">✕</button>
        <h2 class="modal-title">Add Payment</h2>
        <p class="modal-subtitle">Record salary or payment to team member</p>
        <form id="addSalaryForm">
          <div class="form-group">
            <label for="salaryMemberName">Team Member Name</label>
            <input type="text" id="salaryMemberName" placeholder="Enter name" required>
          </div>
          <div class="form-group">
            <label for="salaryAmount">Amount</label>
            <input type="number" id="salaryAmount" placeholder="0" min="0" required>
          </div>
          <div class="form-group">
            <label for="salaryType">Payment Type</label>
            <select id="salaryType">
              <option value="Monthly">Monthly Salary</option>
              <option value="Bonus">Bonus</option>
              <option value="Advance">Advance</option>
              <option value="Partial">Partial Payment</option>
            </select>
          </div>
          <div class="form-group">
            <label for="salaryCurrency">Currency</label>
            <select id="salaryCurrency">
              <option value="USD">USD</option>
              <option value="EUR">EUR</option>
              <option value="INR">INR</option>
              <option value="GBP">GBP</option>
            </select>
          </div>
          <button type="submit" class="submit-btn">Add Payment</button>
          <button type="button" class="cancel-btn" onclick="this.closest('.modal').remove()">Cancel</button>
        </form>
      </div>
    `;
    document.body.appendChild(modal);
    
    modal.querySelector(".modal-overlay").addEventListener("click", () => modal.remove());
    modal.querySelector(".modal-close").addEventListener("click", () => modal.remove());
    
    modal.querySelector("#addSalaryForm").addEventListener("submit", (e) => {
      e.preventDefault();
      const name = document.getElementById("salaryMemberName").value;
      const amount = parseInt(document.getElementById("salaryAmount").value);
      const type = document.getElementById("salaryType").value;
      const currency = document.getElementById("salaryCurrency").value;
      
      // Save to history
      const history = JSON.parse(localStorage.getItem('salaryHistory') || '[]');
      history.push({
        name,
        amount,
        type,
        currency,
        date: new Date().toLocaleDateString()
      });
      localStorage.setItem('salaryHistory', JSON.stringify(history));
      
      // Update salary data
      const salaryData = JSON.parse(localStorage.getItem('userSalaryData') || '{"given": 0, "pending": 0, "currency": "' + currency + '"}');
      salaryData.given += amount;
      salaryData.currency = currency;
      localStorage.setItem('userSalaryData', JSON.stringify(salaryData));
      
      showNotification(`Payment of ${currency} ${amount.toLocaleString()} added for ${name}`);
      modal.remove();
      handleSalaryNav(); // Refresh the view
    });
  }

  function handleViewSalaryHistory() {
    const history = JSON.parse(localStorage.getItem('salaryHistory') || '[]');
    if (history.length === 0) {
      showNotification("No payment history yet.");
    } else {
      showNotification(`Total ${history.length} payments recorded`);
    }
  }

  function handleMemberSidebarNavigation(event) {
    appState.activeTab = event.currentTarget.dataset.nav.toLowerCase();
    updateSidebarSelection(event.currentTarget.dataset.nav);
    renderMemberMainByNav();
  }

  function handleLikeToggle(event) {
    const postId = event.currentTarget.dataset.postId;
    const target = appState.posts.find(item => item.id === postId);
    if (!target) return;
    if (target.liked) {
      target.likes = Math.max(0, target.likes - 1);
    } else {
      target.likes += 1;
    }
    target.liked = !target.liked;
    renderFeed(document.getElementById("memberMainMount"));
  }

  function handleAddTask(event) {
    event.preventDefault();
    const input = document.getElementById("newTaskInput");
    const value = input.value.trim();
    if (!value) return;
    const todoTasks = JSON.parse(localStorage.getItem('todoTasks') || '[]');
    todoTasks.push(value);
    localStorage.setItem('todoTasks', JSON.stringify(todoTasks));
    
    // Add activity
    const activities = JSON.parse(localStorage.getItem('projectActivity') || '[]');
    activities.push(`New task added: ${value}`);
    localStorage.setItem('projectActivity', JSON.stringify(activities));
    
    input.value = "";
    hydrateTaskColumns();
    showNotification("Task added to To Do.");
  }

  function handleSendMessage(event) {
    event.preventDefault();
    const input = document.getElementById("chatInput");
    const value = input.value.trim();
    if (!value) return;
    const sender = appState.user ? appState.user.name : "You";
    const message = `${sender}: ${value}`;
    
    // Save to localStorage
    const messages = JSON.parse(localStorage.getItem('projectChat') || '[]');
    messages.push(message);
    localStorage.setItem('projectChat', JSON.stringify(messages));
    
    // Add to activity
    const activities = JSON.parse(localStorage.getItem('projectActivity') || '[]');
    activities.push(`${sender} sent a message`);
    localStorage.setItem('projectActivity', JSON.stringify(activities));
    
    input.value = "";
    hydrateChat();
    showNotification("Message sent");
  }

  function handleInviteMember() {
    showNotification("Invite sent. Waiting for response.");
  }

  function handleJoinRequestAction(event) {
    const requestId = event.currentTarget.dataset.joinId;
    const action = event.currentTarget.dataset.action;
    dashboardState.creator.joinRequests = dashboardState.creator.joinRequests.filter(item => item.id !== requestId);
    hydrateCreatorRightPanel();
    showNotification(`Join request ${action}d.`);
  }

  function handleCreatePost(event) {
    event.preventDefault();
    const input = document.getElementById("memberPostInput");
    if (!input) return;
    const text = input.value.trim();
    if (!text) return;
    const author = appState.user ? appState.user.name : "You";
    appState.posts.unshift({
      id: `m${Date.now()}`,
      avatar: author.slice(0, 2).toUpperCase(),
      name: author,
      timestamp: "Just now",
      text,
      likes: 0,
      liked: false,
      comments: []
    });
    input.value = "";
    renderFeed(document.getElementById("memberMainMount"));
    showNotification("Post published successfully.");
  }

  function handleProjectSearch(event) {
    const value = event.target.value.trim().toLowerCase();
    const category = document.getElementById("projectCategoryFilter").value;
    const container = document.getElementById("memberProjectsList");
    const list = appState.projects.filter(project => {
      const nameMatch = project.name.toLowerCase().includes(value);
      const categoryMatch = category === "all" || project.category === category;
      return nameMatch && categoryMatch;
    });
    container.innerHTML = list.map(project => `
      <div class="dashboard-card">
        <div class="dashboard-row">
          <strong style="color:#e2e8f0;">${project.name}</strong>
          <span class="tag-chip">${project.status}</span>
        </div>
        <p style="margin:0 0 8px;color:#94a3b8;font-size:13px;">${project.category} • ${project.description || ""}</p>
        <div class="progress-track"><div class="progress-fill" style="width:${project.progress || 0}%"></div></div>
        <div class="dashboard-row" style="margin-top:8px;">
          <span style="font-size:12px;color:#94a3b8;">${project.progress || 0}% complete</span>
          <button class="dashboard-pill-btn" data-open-project="${project.id}">Open</button>
        </div>
      </div>
    `).join("");
    container.querySelectorAll("[data-open-project]").forEach(btn => btn.addEventListener("click", () => showNotification("Project workspace opened.")));
  }

  function handleProjectFilter() {
    const input = document.getElementById("projectSearchInput");
    handleProjectSearch({ target: input });
  }

  function handleConnectToggle(event) {
    const userId = event.currentTarget.dataset.userId;
    const person = appState.people.find(item => item.id === userId);
    if (!person) return;
    person.connected = !person.connected;
    renderPeople(document.getElementById("memberMainMount"));
    showNotification(person.connected ? "Connection request sent." : "Connection removed.");
  }

  function renderProfileDropdown() {
    const existing = document.getElementById("dashboardProfileMenu");
    if (existing) {
      existing.remove();
      return;
    }
    const menu = document.createElement("div");
    menu.id = "dashboardProfileMenu";
    menu.className = "notif-pop";
    menu.style.top = "82px";
    menu.style.bottom = "auto";
    menu.innerHTML = `
      <div style="display:grid;gap:6px;">
        <button class="dashboard-pill-btn" id="profileViewBtn">View Profile</button>
        <button class="dashboard-pill-btn" id="profileEditBtn">Edit Profile</button>
        <button class="dashboard-pill-btn" id="profileSkillsBtn">Skills & Hobbies</button>
        <button class="dashboard-pill-btn" id="profileProjectsBtn">My Projects</button>
        <button class="dashboard-pill-btn" id="profileLogoutBtn">Logout</button>
      </div>
    `;
    document.body.appendChild(menu);
    menu.querySelector("#profileViewBtn").addEventListener("click", openUserProfileModal);
    menu.querySelector("#profileEditBtn").addEventListener("click", () => {
      existing.remove();
      openEditProfile();
    });
    menu.querySelector("#profileSkillsBtn").addEventListener("click", () => {
      const user = JSON.parse(localStorage.getItem('user') || '{}');
      const skills = (user.skills || []).join(", ");
      const hobbies = (user.hobbies || []).join(", ");
      showNotification(`Skills: ${skills || "None"}\nHobbies: ${hobbies || "None"}`);
    });
    menu.querySelector("#profileProjectsBtn").addEventListener("click", () => showNotification(`You are working on: ${appState.currentProject ? appState.currentProject.name : "No active project"}`));
    menu.querySelector("#profileLogoutBtn").addEventListener("click", logout);
    setTimeout(() => {
      document.addEventListener("click", closeProfileMenuOnOutside, { once: true });
    }, 0);
  }

  function openUserProfileModal() {
    const user = JSON.parse(localStorage.getItem('user') || '{}');
    const profile = JSON.parse(localStorage.getItem('makeBigProfile') || '{}');
    
    const modal = document.createElement("div");
    modal.className = "modal active";
    modal.innerHTML = `
      <div class="modal-overlay"></div>
      <div class="modal-content" style="max-width: 520px;">
        <button class="modal-close" type="button">✕</button>
        <h2 class="modal-title">${user.name || "Your Profile"}</h2>
        <p class="modal-subtitle">${profile.tagline || "Profile details"}</p>
        <div class="dashboard-card">
          <div class="dashboard-row" style="margin-bottom: 12px;">
            <span style="color: #94a3b8;">Name:</span>
            <span style="color: #cbd5e1;">${user.name || "Not set"}</span>
          </div>
          <div class="dashboard-row" style="margin-bottom: 12px;">
            <span style="color: #94a3b8;">Contact:</span>
            <span style="color: #cbd5e1;">${user.contact || "Not set"}</span>
          </div>
          <div class="dashboard-row" style="margin-bottom: 12px;">
            <span style="color: #94a3b8;">Profile Type:</span>
            <span style="color: #cbd5e1;">${profile.role || "Not set"}</span>
          </div>
          ${user.skills && user.skills.length ? `
          <div style="margin-bottom: 12px;">
            <span style="color: #94a3b8; display: block; margin-bottom: 6px;">Skills:</span>
            <div style="display: flex; flex-wrap: wrap; gap: 6px;">
              ${user.skills.map(s => `<span class="tag-chip">${s}</span>`).join("")}
            </div>
          </div>
          ` : ""}
          ${user.hobbies && user.hobbies.length ? `
          <div style="margin-bottom: 12px;">
            <span style="color: #94a3b8; display: block; margin-bottom: 6px;">Hobbies:</span>
            <div style="display: flex; flex-wrap: wrap; gap: 6px;">
              ${user.hobbies.map(h => `<span class="tag-chip">${h}</span>`).join("")}
            </div>
          </div>
          ` : ""}
          ${profile.rateMin && profile.rateMax ? `
          <div class="dashboard-row" style="margin-bottom: 12px;">
            <span style="color: #94a3b8;">Expected Rate:</span>
            <span style="color: #cbd5e1;">${profile.currency} ${profile.rateMin} - ${profile.rateMax} / month</span>
          </div>
          ` : ""}
          <div class="inline-form">
            <button type="button" class="dashboard-pill-btn" id="openEditFromModal" style="flex: 1;">Edit Profile</button>
            <button type="button" class="dashboard-pill-btn" id="closeProfileModal" style="flex: 1;">Close</button>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    
    modal.querySelector(".modal-overlay").addEventListener("click", () => modal.remove());
    modal.querySelector(".modal-close").addEventListener("click", () => modal.remove());
    modal.querySelector("#closeProfileModal").addEventListener("click", () => modal.remove());
    modal.querySelector("#openEditFromModal").addEventListener("click", () => {
      modal.remove();
      openEditProfile();
    });
  }

  function closeProfileMenuOnOutside(event) {
    const menu = document.getElementById("dashboardProfileMenu");
    if (!menu) return;
    if (!menu.contains(event.target)) menu.remove();
  }

  function toggleMemberDropdown(targetId) {
    const target = document.getElementById(targetId);
    if (!target) return;
    const all = document.querySelectorAll(".dropdown-panel");
    all.forEach(panel => {
      if (panel.id !== targetId) panel.classList.remove("show");
    });
    target.classList.toggle("show");
  }

  function renderCreatorDashboard(root) {
    root.innerHTML = "";
    const shell = document.createElement("div");
    shell.className = "dashboard-shell";
    const topBar = createTopBar();
    const sidebar = createSidebar(["Dashboard", "Projects", "Team", "Chat", "Tasks", "Salary", "Files", "Feed", "Meetings", "Settings"], dashboardState.creator.activeNav, handleCreatorSidebarNavigation);
    const main = document.createElement("main");
    main.className = "dashboard-main";
    const right = document.createElement("aside");
    right.className = "dashboard-right";
    shell.appendChild(topBar);
    shell.appendChild(sidebar);
    shell.appendChild(main);
    shell.appendChild(right);
    root.appendChild(shell);
    renderCreatorMainSections(main);
    renderCreatorRightSections(right);
    updateTopBarProjectName();
  }

  function renderMemberDashboard(root) {
    root.innerHTML = "";
    const shell = document.createElement("div");
    shell.className = "member-main-wrap";
    const topBar = document.createElement("header");
    topBar.className = "dashboard-topbar member-topbar";
    topBar.innerHTML = `
      <h3 id="dashboardProjectName">Make Big</h3>
      <div class="topbar-search"><input id="dashboardSearch" type="text" placeholder="Search projects, people, posts..."></div>
      <div class="member-top-icons">
        <button id="memberBellBtn" class="icon-btn" type="button">🔔<span class="icon-badge">${appState.notifications.length}</span></button>
        <button id="memberProfileBtn" class="icon-btn" type="button">👤</button>
        <div id="memberNotifDropdown" class="dropdown-panel"></div>
        <div id="memberProfileDropdown" class="dropdown-panel"></div>
      </div>
    `;

    const tabBar = document.createElement("div");
    tabBar.className = "member-tabbar";
    const tabs = [
      { id: "home", label: "Home" },
      { id: "recommended", label: "Recommended" },
      { id: "projects", label: "Projects" },
      { id: "people", label: "People" }
    ];
    tabs.forEach(tab => {
      const button = document.createElement("button");
      button.className = `member-tab-btn ${appState.activeTab === tab.id ? "active" : ""}`;
      button.type = "button";
      button.dataset.tab = tab.id;
      button.textContent = tab.label;
      button.addEventListener("click", () => {
        appState.activeTab = tab.id;
        renderMemberMainByNav();
      });
      tabBar.appendChild(button);
    });

    const main = document.createElement("main");
    main.className = "dashboard-main member-content";
    main.id = "memberMainMount";
    shell.appendChild(topBar);
    shell.appendChild(tabBar);
    shell.appendChild(main);
    root.appendChild(shell);

    topBar.querySelector("#memberBellBtn").addEventListener("click", () => {
      renderNotificationsDropdown();
      toggleMemberDropdown("memberNotifDropdown");
    });
    topBar.querySelector("#memberProfileBtn").addEventListener("click", () => {
      renderMemberProfileDropdown();
      toggleMemberDropdown("memberProfileDropdown");
    });
    renderMemberMainByNav();
    updateTopBarProjectName();
  }

  function renderMemberMainByNav() {
    const mount = document.getElementById("memberMainMount");
    if (!mount) return;
    if (appState.activeTab === "home") renderFeed(mount);
    if (appState.activeTab === "recommended") renderRecommendedTab(mount);
    if (appState.activeTab === "projects") renderProjects(mount);
    if (appState.activeTab === "people") renderPeople(mount);
    document.querySelectorAll(".member-tab-btn").forEach(btn => btn.classList.toggle("active", btn.dataset.tab === appState.activeTab));
  }

  function renderFeed(mount) {
    mount.innerHTML = "";
    const createPost = document.createElement("section");
    createPost.className = "dashboard-card";
    createPost.innerHTML = `
      <h4>Post Creation Box</h4>
      <form id="memberPostForm" class="inline-form">
        <input id="memberPostInput" type="text" placeholder="Share your update...">
        <button type="submit">Post</button>
      </form>
    `;
    createPost.querySelector("#memberPostForm").addEventListener("submit", handleCreatePost);
    const feedCard = document.createElement("section");
    feedCard.className = "dashboard-card";
    feedCard.innerHTML = `<h4>Home Feed</h4><div id="memberFeedList"></div>`;
    const recommendationCard = document.createElement("section");
    recommendationCard.className = "dashboard-card";
    recommendationCard.innerHTML = `<h4>🔥 Recommended Projects For You</h4><div id="recommendationList" class="recommend-row"></div>`;
    mount.appendChild(createPost);
    mount.appendChild(feedCard);
    mount.appendChild(recommendationCard);
    hydrateMemberFeed();
    renderRecommendations();
  }

  function renderRecommendedTab(mount) {
    mount.innerHTML = "";
    const recommendationCard = document.createElement("section");
    recommendationCard.className = "dashboard-card";
    recommendationCard.innerHTML = `<h4>Recommended Projects</h4><div id="recommendationList" class="recommend-row"></div>`;
    mount.appendChild(recommendationCard);
    renderRecommendations();
  }

  function renderProjects(mount) {
    mount.innerHTML = "";
    const section = document.createElement("section");
    section.className = "dashboard-card";
    const categoryOptions = [
      `<option value="all">All categories</option>`,
      ...wizardCategories.map(c => `<option value="${c.title.replace(/"/g, "&quot;")}">${c.title}</option>`)
    ].join("");
    section.innerHTML = `
      <h4>Projects</h4>
      <p style="margin:0 0 10px;color:#94a3b8;font-size:13px;line-height:1.4;">
        ${appState.currentProject ? `Showing matches for your profile (${appState.currentProject.category}).` : "You have no active collaboration yet — finish Start a Project first."}
      </p>
      <div class="inline-form" style="margin-bottom:10px;">
        <input id="projectSearchInput" type="text" placeholder="Search projects">
        <select id="projectCategoryFilter" style="border:1px solid rgba(148,163,184,0.3);background:rgba(15,23,42,0.75);color:#e2e8f0;border-radius:10px;padding:9px 10px;">
          ${categoryOptions}
        </select>
      </div>
      <div id="memberProjectsList" class="mini-grid"></div>
    `;
    mount.appendChild(section);
    const searchInput = section.querySelector("#projectSearchInput");
    const categoryFilter = section.querySelector("#projectCategoryFilter");
    searchInput.addEventListener("input", handleProjectSearch);
    categoryFilter.addEventListener("change", handleProjectFilter);
    handleProjectFilter();
  }

  function renderPeople(mount) {
    mount.innerHTML = "";
    const section = document.createElement("section");
    section.className = "dashboard-card";
    section.innerHTML = `
      <h4>People</h4>
      <div class="inline-form" style="margin-bottom:10px;">
        <input id="peopleSearchInput" type="text" placeholder="Search people">
      </div>
      <div id="memberPeopleList"></div>
    `;
    mount.appendChild(section);
    const list = section.querySelector("#memberPeopleList");
    const renderList = () => {
      const query = section.querySelector("#peopleSearchInput").value.trim().toLowerCase();
      const filtered = appState.people.filter(person => person.name.toLowerCase().includes(query) || person.skills.toLowerCase().includes(query));
      list.innerHTML = "";
      filtered.forEach(person => {
        const row = document.createElement("div");
        row.className = "dashboard-row";
        row.style.border = "1px solid rgba(148,163,184,0.2)";
        row.style.borderRadius = "10px";
        row.style.padding = "8px";
        row.style.marginBottom = "7px";
        row.innerHTML = `
          <div>
            <div style="display:flex;align-items:center;gap:8px;">
              <span class="feed-avatar">${person.avatar}</span>
              <div>
                <div style="color:#e2e8f0;font-size:13px;">${person.name}</div>
                <div style="color:#94a3b8;font-size:12px;">${person.skills}</div>
              </div>
            </div>
            <div style="color:#94a3b8;font-size:12px;margin-top:6px;">${person.bio}</div>
          </div>
          <div style="display:flex;gap:6px;">
            <button class="dashboard-pill-btn" data-user-id="${person.id}" data-action="connect">${person.connected ? "Connected" : "Connect"}</button>
            <button class="dashboard-pill-btn" data-open-person="${person.id}">View</button>
          </div>
        `;
        row.querySelector('[data-action="connect"]').addEventListener("click", handleConnectToggle);
        row.querySelector('[data-open-person]').addEventListener("click", () => openPersonProfileModal(person));
        list.appendChild(row);
      });
    };
    section.querySelector("#peopleSearchInput").addEventListener("input", renderList);
    renderList();
  }

  function renderNotifications(mount) {
    mount.innerHTML = "";
    const section = document.createElement("section");
    section.className = "dashboard-card";
    section.innerHTML = `<h4>Notifications</h4><div id="memberNotifications"></div>`;
    mount.appendChild(section);
    section.querySelector("#memberNotifications").innerHTML = appState.notifications.map(item => `<div class="tag-chip" style="margin-bottom:6px;">${item}</div>`).join("");
  }

  function renderProfile(mount) {
    mount.innerHTML = "";
    const project = appState.currentProject || {};
    const user = appState.user || { name: "User", skills: [], hobbies: [] };
    const userName = user.name;
    const section = document.createElement("section");
    section.className = "dashboard-card";
    const userSkills = (user.skills || []).length > 0 ? user.skills.join(", ") : "No skills added";
    const userHobbies = (user.hobbies || []).length > 0 ? user.hobbies.join(", ") : "No hobbies added";
    
    section.innerHTML = `
      <h4>Profile</h4>
      <p style="margin:0 0 8px;color:#cbd5e1;"><strong>${userName}</strong></p>
      <p style="margin:0 0 8px;color:#94a3b8;">Connections: ${appState.people.filter(person => person.connected).length}</p>
      <p style="margin:0 0 8px;color:#94a3b8;"><strong>Skills:</strong> ${userSkills}</p>
      <p style="margin:0 0 8px;color:#94a3b8;"><strong>Hobbies:</strong> ${userHobbies}</p>
      <p style="margin:0 0 8px;color:#94a3b8;">My Posts: ${appState.posts.length}</p>
      <p style="margin:0 0 8px;color:#94a3b8;">My Projects: ${appState.projects.length}</p>
      <p style="margin:0 0 12px;color:#94a3b8;">Current Project: ${project.name || "None"}</p>
      <div class="inline-form">
        <button type="button" id="memberEditProfileBtn" class="dashboard-pill-btn" style="flex: 1;">Edit Profile</button>
        <button type="button" id="memberLogoutBtn" class="dashboard-pill-btn" style="flex: 1;">Logout</button>
      </div>
    `;
    mount.appendChild(section);
    section.querySelector("#memberEditProfileBtn").addEventListener("click", openEditProfile);
    section.querySelector("#memberLogoutBtn").addEventListener("click", logout);
  }

  function renderNotificationsDropdown() {
    const dropdown = document.getElementById("memberNotifDropdown");
    if (!dropdown) return;
    apiGetNotifications();
    dropdown.innerHTML = `
      <h4 style="margin:0 0 8px;color:#7dd3fc;font-size:14px;">Notifications</h4>
      ${appState.notifications.map(item => `<div class="tag-chip" style="margin-bottom:6px;">${item}</div>`).join("")}
    `;
  }

  function renderMemberProfileDropdown() {
    const dropdown = document.getElementById("memberProfileDropdown");
    if (!dropdown) return;
    const userName = appState.user ? appState.user.name : "User";
    dropdown.innerHTML = `
      <h4 style="margin:0 0 8px;color:#7dd3fc;font-size:14px;">${userName}</h4>
      <button class="dashboard-pill-btn" id="dropdownViewProfile" style="width:100%;margin-bottom:6px;">View Profile</button>
      <button class="dashboard-pill-btn" id="dropdownEditProfile" style="width:100%;margin-bottom:6px;">Edit Profile</button>
      <button class="dashboard-pill-btn" id="dropdownMyProjects" style="width:100%;margin-bottom:6px;">My Projects</button>
      <button class="dashboard-pill-btn" id="dropdownLogout" style="width:100%;">Logout</button>
    `;
    dropdown.querySelector("#dropdownViewProfile").addEventListener("click", () => {
      const mount = document.getElementById("memberMainMount");
      if (mount) renderProfile(mount);
    });
    dropdown.querySelector("#dropdownEditProfile").addEventListener("click", () => openEditProfile());
    dropdown.querySelector("#dropdownMyProjects").addEventListener("click", () => {
      appState.activeTab = "projects";
      renderMemberMainByNav();
    });
    dropdown.querySelector("#dropdownLogout").addEventListener("click", logout);
  }

  function openPersonProfileModal(person) {
    const existing = document.getElementById("personProfileModal");
    if (existing) existing.remove();
    const modal = document.createElement("div");
    modal.id = "personProfileModal";
    modal.className = "modal active";
    modal.innerHTML = `
      <div class="modal-overlay"></div>
      <div class="modal-content" style="max-width:520px;">
        <button class="modal-close" type="button">✕</button>
        <h2 class="modal-title">${person.name}</h2>
        <p class="modal-subtitle">${person.skills}</p>
        <div class="dashboard-card">
          <p style="margin:0 0 8px;color:#cbd5e1;">${person.bio}</p>
          <p style="margin:0 0 8px;color:#94a3b8;">Skills: ${person.skills}</p>
          <p style="margin:0 0 10px;color:#94a3b8;">Active Projects: ${(person.activeProjects || []).join(", ")}</p>
          <div class="inline-form">
            <button type="button" class="dashboard-pill-btn" id="personConnectBtn">${person.connected ? "Connected" : "Connect"}</button>
            <button type="button" class="dashboard-pill-btn" id="personMessageBtn">Message</button>
          </div>
        </div>
      </div>
    `;
    document.body.appendChild(modal);
    modal.querySelector(".modal-overlay").addEventListener("click", () => modal.remove());
    modal.querySelector(".modal-close").addEventListener("click", () => modal.remove());
    modal.querySelector("#personConnectBtn").addEventListener("click", () => {
      person.connected = !person.connected;
      showNotification(person.connected ? `Connected with ${person.name}` : `Disconnected from ${person.name}`);
      modal.remove();
      renderPeople(document.getElementById("memberMainMount"));
    });
    modal.querySelector("#personMessageBtn").addEventListener("click", () => showNotification(`Message sent to ${person.name}`));
  }

  function showNotification(message) {
    const existing = document.getElementById("dashboardNotificationPopup");
    if (existing) existing.remove();
    const popup = document.createElement("div");
    popup.id = "dashboardNotificationPopup";
    popup.className = "notif-pop";
    popup.textContent = message;
    document.body.appendChild(popup);
    setTimeout(() => {
      if (popup.parentNode) popup.parentNode.removeChild(popup);
    }, 2200);
  }

  // Handle auth form submissions
  document.getElementById('signinFormEl').addEventListener('submit', handleSignin);
  document.getElementById('signupFormEl').addEventListener('submit', handleSignup);
  document.getElementById('editProfileForm').addEventListener('submit', saveProfile);

  // Close auth modal when pressing ESC
  document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
      closeAuthModal();
      closeProjectModal();
    }
  });

</script>

</body>
