      <div class="mini-grid">
        <div class="tag-chip">
          <strong>${currentProject.name || 'Untitled Project'}</strong>
          <div style="font-size: 11px; color: #94a3b8; margin-top: 4px;">${currentProject.category || 'General'}</div>
        </div>
