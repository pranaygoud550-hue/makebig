  function formatSalaryBand(minV, maxV, cur) {
    return `${cur} ${Number(minV).toLocaleString()} – ${Number(maxV).toLocaleString()} / month`;
  }

  async function apiGetSeed() {
    try {
      const res = await fetch("/api/seed", { method: "GET" });
      if (!res.ok) return;
      const data = await res.json();
      if (Array.isArray(data.people) && data.people.length) MOCK_INVITE_CREATORS = data.people;
      if (Array.isArray(data.openMarketProjects) && data.openMarketProjects.length) OPEN_MARKET_PROJECTS = data.openMarketProjects;
    } catch (e) {
      // If server isn't running (opening index.html directly), keep frontend defaults.
    }
  }

  async function apiGetNotifications() {
    try {
      const contact = appState.user && appState.user.contact ? appState.user.contact : "";
      if (!contact) return;
      const res = await fetch(`/api/notifications?contact=${encodeURIComponent(contact)}`, { method: "GET" });
      if (!res.ok) return;
      const data = await res.json();
      if (Array.isArray(data.notifications)) {
        appState.notifications = data.notifications.map(n => n.message);
      }
    } catch (e) {}
  }

  function budgetBandOverlapScore(projMin, projMax, rateMin, rateMax) {
    if (!Number.isFinite(projMin) || !Number.isFinite(projMax) || projMax < projMin) return 50;
    const lo = Math.max(projMin, rateMin);
    const hi = Math.min(projMax, rateMax);
    if (hi >= lo) {
      const overlap = hi - lo + 1;
      const pSpan = Math.max(projMax - projMin + 1, 1);
      const cSpan = Math.max(rateMax - rateMin + 1, 1);
      return Math.min(100, Math.round(55 + (overlap / Math.min(pSpan, cSpan)) * 45));
    }
    const gap = Math.min(Math.abs(rateMax - projMin), Math.abs(projMax - rateMin));
    const scale = Math.max(projMax, rateMax, 1);
    return Math.max(8, Math.round(45 - (gap / scale) * 80));
  }

  function normalizeSkillLabel(s) {
    return String(s || "").toLowerCase().replace(/\s+/g, " ").trim();
  }

  function skillAlignmentForInvite(selectedSkills, person) {
    const pNorm = person.skills.map(normalizeSkillLabel);
    const hay = `${person.tagline} ${pNorm.join(" ")}`.toLowerCase();
    let exact = 0;
    let partial = 0;
    (selectedSkills || []).forEach(sel => {
      const n = normalizeSkillLabel(sel);
      if (!n) return;
      const hit = pNorm.some(ps => ps === n || ps.includes(n) || n.includes(ps));
      if (hit) exact += 1;
      else if (hay.includes(n) || n.split(/[/\s]+/).some(part => part.length > 3 && hay.includes(part))) partial += 1;
    });
    const exactScore = Math.min(48, exact * 16);
    const partialScore = Math.min(22, partial * 9);
    return { exact, partial, skillScore: exactScore + partialScore };
  }

  function extractInviteKeywords() {
    const chunks = [
      document.getElementById("wizardProjectName")?.value || "",
      document.getElementById("wizardShortDesc")?.value || "",
      document.getElementById("wizardVision")?.value || ""
    ].join(" ");
    const raw = chunks.toLowerCase().match(/[a-z0-9][a-z0-9+#.]{2,}/g) || [];
    const stop = new Set(["the", "and", "for", "with", "this", "that", "from", "your", "our", "are", "you", "want", "will", "can", "has", "have", "was", "were", "into", "about", "team", "project", "build", "make", "need", "looking"]);
    return raw.filter(w => !stop.has(w)).slice(0, 40);
  }

  function keywordBoostForInvite(keywords, person) {
    if (!keywords.length) return 0;
    const hay = `${person.tagline} ${person.skills.join(" ")}`.toLowerCase();
    let hits = 0;
    keywords.forEach(k => {
      if (hay.includes(k)) hits += 1;
    });
    return Math.min(28, hits * 5);
  }

  function scoreInvitePerson(person, ctx) {
    const catPts = person.categoryIds.includes(ctx.categoryId) ? 22 : 0;
    const { skillScore } = skillAlignmentForInvite(ctx.selectedSkills, person);
    const budgetPts = budgetBandOverlapScore(ctx.projMin, ctx.projMax, person.rateMin, person.rateMax);
    const keyPts = keywordBoostForInvite(ctx.keywords, person);
    const raw = catPts + skillScore + budgetPts * 0.55 + keyPts;
    return Math.min(100, Math.round(raw));
  }

  function salaryExpectationFit(expect, project) {
    if (!expect || Number.isNaN(expect)) return 74;
    if (expect >= project.salaryMin && expect <= project.salaryMax) return 100;
    const mid = (project.salaryMin + project.salaryMax) / 2;
    const drift = Math.abs(expect - mid) / Math.max(expect, mid);
    return Math.max(40, Math.round(100 - drift * 110));
  }

  function countSkillSignals(skills, roleBlob) {
    if (!skills || !skills.length) return 2;
    const blob = Array.isArray(roleBlob) ? roleBlob.join(" ").toLowerCase() : String(roleBlob).toLowerCase();
    let hits = 0;
    skills.forEach(skill => {
      skill
        .toLowerCase()
        .split(/[^a-z0-9+.#]+/)
        .forEach(tok => {
          if (tok.length > 2 && blob.includes(tok)) hits += 1;
        });
    });
    return Math.min(hits, 8);
  }

  function buildMarketMatches(categoryId, skills, expectMonthly) {
    const expectNum = typeof expectMonthly === "number" && !Number.isNaN(expectMonthly) ? expectMonthly : null;
    const pool = OPEN_MARKET_PROJECTS.filter(p => p.categoryId === categoryId);
    const source = pool.length ? pool : OPEN_MARKET_PROJECTS;
    const rows = source.map(proj => {
      const skillHits = countSkillSignals(skills, proj.roles);
      const salaryScore = salaryExpectationFit(expectNum, proj);
      const score = Math.min(96, Math.round(skillHits * 14 + salaryScore * 0.42 + 12));
      return {
        id: proj.id,
        name: proj.name,
        category: wizardCategories.find(c => c.id === proj.categoryId)?.title || proj.categoryId,
        desc: proj.desc,
        roles: proj.roles.slice(),
        match: score,
        salaryLabel: formatSalaryBand(proj.salaryMin, proj.salaryMax, proj.currency)
      };
    }).sort((a, b) => b.match - a.match);
    return rows;
  }

