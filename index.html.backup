      <div class="dashboard-row">
        <h4 style="margin:0;">Task Board</h4>
        <form id="addTaskForm" class="inline-form" style="max-width:350px;">
          <input id="newTaskInput" type="text" placeholder="Add new task">
          <button type="submit">Add Task</button>
        </form>
      </div>
      <div class="board-columns">
        <div class="board-col"><h5>To Do</h5><div id="todoTasks"></div></div>
        <div class="board-col"><h5>In Progress</h5><div id="inProgressTasks"></div></div>
        <div class="board-col"><h5>Completed</h5><div id="completedTasks"></div></div>
      </div>
    `;
    section.querySelector("#addTaskForm").addEventListener("submit", handleAddTask);
    return section;
  }

