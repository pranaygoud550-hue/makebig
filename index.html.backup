<!DOCTYPE html>
<html>
<head>
  <title>Make Big</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: #0f172a;
      color: white;
      overflow-x: hidden;
    }

    /* ================= SPLASH SCREEN ================= */
    #splash {
      position: fixed;
      width: 100%;
      height: 100vh;
      background: linear-gradient(135deg, #0b1220, #111c33);
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      z-index: 9999;
    }

    .scene {
      position: relative;
      width: 520px;
      height: 340px;
    }

    .brand-title {
      position: absolute;
      top: 20px;
      width: 100%;
      text-align: center;
      font-size: 48px;
      font-weight: 800;
      letter-spacing: 6px;
      color: #38bdf8;
      text-transform: uppercase;
    }

    .brand-subtitle {
      position: absolute;
      top: 232px;
      width: 100%;
      text-align: center;
      color: #cbd5e1;
      font-size: 16px;
      letter-spacing: 2px;
      text-transform: none;
    }

    .stick-word {
      position: absolute;
      top: 98px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 10px;
      align-items: flex-end;
      z-index: 2;
    }

    .stick-letter {
      position: relative;
      width: 58px;
      height: 120px;
    }

    .stick-letter .bar {
      position: absolute;
      background: #38bdf8;
      border-radius: 5px;
      transform-origin: top left;
      animation: assemble 0.8s ease forwards;
      animation-fill-mode: forwards;
      opacity: 0;
      transform: scaleY(0.2);
    }

    .letter-m .bar1 { left: 0; top: 0; width: 12px; height: 100%; animation-delay: 0.05s; }
    .letter-m .bar2 { left: 24px; top: 0; width: 12px; height: 72px; transform: rotate(48deg); animation-delay: 0.12s; }
    .letter-m .bar3 { left: 38px; top: 0; width: 12px; height: 72px; transform: rotate(-48deg); animation-delay: 0.18s; }
    .letter-m .bar4 { left: 56px; top: 0; width: 12px; height: 100%; animation-delay: 0.24s; }

    .letter-a .bar1 { left: 0; top: 0; width: 12px; height: 100%; animation-delay: 0.30s; }
    .letter-a .bar2 { right: 0; top: 0; width: 12px; height: 100%; animation-delay: 0.36s; }
    .letter-a .bar3 { left: 10px; bottom: 32px; width: 46px; height: 12px; animation-delay: 0.42s; }

    .letter-k .bar1 { left: 0; top: 0; width: 12px; height: 100%; animation-delay: 0.48s; }
    .letter-k .bar2 { left: 16px; top: 28px; width: 12px; height: 70px; transform: rotate(28deg); animation-delay: 0.54s; }
    .letter-k .bar3 { left: 16px; top: 58px; width: 12px; height: 70px; transform: rotate(-28deg); animation-delay: 0.60s; }

    .letter-e .bar1 { left: 0; top: 0; width: 12px; height: 100%; animation-delay: 0.66s; }
    .letter-e .bar2 { left: 12px; top: 0; width: 46px; height: 12px; animation-delay: 0.72s; }
    .letter-e .bar3 { left: 12px; top: 52px; width: 46px; height: 12px; animation-delay: 0.78s; }
    .letter-e .bar4 { left: 12px; bottom: 0; width: 46px; height: 12px; animation-delay: 0.84s; }

    .letter-b .bar1 { left: 0; top: 0; width: 12px; height: 100%; animation-delay: 0.90s; }
    .letter-b .bar2 { left: 12px; top: 0; width: 48px; height: 12px; animation-delay: 0.96s; }
    .letter-b .bar3 { left: 12px; top: 52px; width: 48px; height: 12px; animation-delay: 1.02s; }
    .letter-b .bar4 { left: 12px; bottom: 0; width: 48px; height: 12px; animation-delay: 1.08s; }
    .letter-b .bar5 { right: 0; top: 14px; width: 12px; height: 34px; border-radius: 5px; animation-delay: 1.14s; }
    .letter-b .bar6 { right: 0; bottom: 14px; width: 12px; height: 34px; border-radius: 5px; animation-delay: 1.20s; }

    .letter-i .bar1 { left: 29px; top: 0; width: 12px; height: 100%; animation-delay: 1.26s; }
    .letter-i .bar2 { left: 10px; top: 0; width: 50px; height: 12px; animation-delay: 1.32s; }
    .letter-i .bar3 { left: 10px; bottom: 0; width: 50px; height: 12px; animation-delay: 1.38s; }

    .letter-g .bar1 { left: 0; top: 0; width: 12px; height: 100%; animation-delay: 1.44s; }
    .letter-g .bar2 { left: 12px; top: 0; width: 50px; height: 12px; animation-delay: 1.50s; }
    .letter-g .bar3 { left: 12px; bottom: 0; width: 50px; height: 12px; animation-delay: 1.56s; }
    .letter-g .bar4 { right: 0; top: 52px; width: 24px; height: 12px; animation-delay: 1.62s; }
    .letter-g .bar5 { right: 0; top: 34px; width: 12px; height: 24px; animation-delay: 1.68s; }

    @keyframes assemble {
      from { transform: scaleY(0.2); opacity: 0; }
      to { transform: scaleY(1); opacity: 1; }
    }

    /* soft cinematic glow */
    .light {
      position: absolute;
      width: 220px;
      height: 220px;
      background: rgba(56,189,248,0.12);
      border-radius: 50%;
      filter: blur(35px);
      top: 40px;
      left: 150px;
    }

    /* TABLE */
    .table {
      position: absolute;
      bottom: 80px;
      width: 100%;
      height: 10px;
      background: #334155;
      border-radius: 10px;
    }

    /* PERSON */
    .person {
      position: absolute;
      bottom: 90px;
      width: 70px;
      height: 120px;
    }

    .head {
      width: 22px;
      height: 22px;
      background: #e2e8f0;
      border-radius: 50%;
      margin: auto;
    }

    .body {
      width: 16px;
      height: 80px;
      background: #38bdf8;
      margin: auto;
      border-radius: 10px;
    }

    .arm {
      position: absolute;
      top: 55px;
      width: 36px;
      height: 8px;
      background: #38bdf8;
      border-radius: 6px;
    }

    .arm.left { left: -40px; }
    .arm.right { right: -40px; }

    /* POSITIONS */
    .center { left: calc(50% - 35px); }

    /* TEA CUPS */
    .cup {
      width: 16px;
      height: 16px;
      background: #f59e0b;
      border-radius: 50%;
      position: absolute;
      bottom: 105px;
      animation: steam 1.3s infinite alternate;
    }

    .cup1 { left: 95px; }
    .cup2 { right: 95px; }

    @keyframes steam {
      0% { transform: translateY(0px) scale(1); opacity: 0.6; }
      100% { transform: translateY(-6px) scale(1.2); opacity: 1; }
    }

    /* HANDSHAKE BAR (CENTER FOCUS) */
    .handshake {
      position: absolute;
      top: 150px;
      left: calc(50% - 60px);
      width: 120px;
      height: 8px;
      background: #f8fafc;
      border-radius: 5px;
      animation: shake 1.2s infinite alternate;
    }

    @keyframes shake {
      0% { transform: translateY(0px); }
      100% { transform: translateY(8px); }
    }

    .cup1 { left: calc(50% - 80px); }
    .cup2 { left: calc(50% + 60px); }

    .splash-btn {
      margin-top: 26px;
      padding: 14px 28px;
      background: #38bdf8;
      color: #020617;
      border: none;
      border-radius: 999px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .splash-btn:hover {
      transform: translateY(-2px);
      opacity: 0.98;
    }

    /* LOADING TEXT */
    .loading-text {
      margin-top: 18px;
      color: #94a3b8;
      font-size: 15px;
      animation: fade 2s infinite;
    }

    @keyframes fade {
      0%,100% { opacity: 0.4; }
      50% { opacity: 1; }
    }

    /* ================= MAIN WEBSITE ================= */

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15px 30px;
      background: #020617;
    }

    .logo {
      font-size: 22px;
      font-weight: bold;
      color: #38bdf8;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 20px;
    }

    .nav-links a {
      color: white;
      text-decoration: none;
    }

    .auth-btn {
      padding: 8px 16px;
      background: #38bdf8;
      color: #0f172a;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .auth-btn:hover {
      background: #0ea5e9;
    }

    .user-info {
      color: #cbd5e1;
      font-size: 14px;
    }

    .logout-btn {
      background: transparent;
      color: #94a3b8;
      border: 1px solid #334155;
      padding: 6px 12px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.2s ease;
    }

    .logout-btn:hover {
      color: #38bdf8;
      border-color: #38bdf8;
    }

    .nav-left {
      display: flex;
      align-items: center;
      gap: 16px;
      position: relative;
    }

    .profile {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(56, 189, 248, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      border: 1px solid rgba(56, 189, 248, 0.25);
      transition: all 0.2s ease;
    }

    .profile:hover {
      background: rgba(56, 189, 248, 0.25);
    }

    .profile.hidden {
      display: none;
    }

    .avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #38bdf8;
      color: #0f172a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 14px;
    }

    .profile-menu {
      position: absolute;
      top: 60px;
      left: 0;
      width: 240px;
      background: #1e293b;
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 14px;
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.25);
      padding: 16px;
      display: none;
      z-index: 10002;
      animation: fadeIn 0.2s ease;
    }

    .profile-menu.active {
      display: block;
    }

    .profile-menu p {
      margin: 0 0 8px;
      color: #cbd5e1;
      font-size: 14px;
      line-height: 1.4;
    }

    .profile-menu button {
      width: 100%;
      margin-top: 8px;
      padding: 10px 12px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 600;
      color: #f8fafc;
      background: rgba(56, 189, 248, 0.15);
      transition: all 0.2s ease;
    }

    .profile-menu button:hover {
      background: rgba(56, 189, 248, 0.25);
    }

    .profile-menu .logout-btn {
      background: transparent;
      color: #f8fafc;
      border: 1px solid rgba(148, 163, 184, 0.2);
      margin-top: 12px;
    }

    .auth-message {
      margin: 0 0 18px;
      color: #94a3b8;
      font-size: 14px;
      padding: 12px 16px;
      background: rgba(15, 23, 42, 0.65);
      border: 1px solid rgba(56, 189, 248, 0.15);
      border-radius: 12px;
      text-align: center;
    }

    .edit-profile-modal .modal-content {
      max-width: 440px;
    }

    .edit-profile-modal .submit-btn {
      width: 100%;
    }

    .edit-profile-modal .cancel-btn {
      width: 100%;
      margin-top: 12px;
      background: transparent;
      border: 1px solid #334155;
      color: #cbd5e1;
    }

    .hero {
      text-align: center;
      margin-top: 120px;
      padding: 20px;
    }

    .hero h1 {
      font-size: 55px;
    }

    .hero p {
      color: #94a3b8;
      font-size: 18px;
    }

    .btn {
      margin-top: 25px;
      padding: 12px 25px;
      background: #3b82f6;
      border: none;
      color: white;
      border-radius: 6px;
      cursor: pointer;
    }

    .skills {
      margin-top: 100px;
      text-align: center;
      padding: 20px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      max-width: 1000px;
      margin: auto;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card h3 {
      color: #38bdf8;
    }

    .footer {
      text-align: center;
      margin-top: 80px;
      padding: 20px;
      color: #64748b;
    }

    /* ================= PROJECT MODAL ================= */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 10000;
    }

    .modal.active {
      display: flex;
      justify-content: center;
      align-items: center;
      animation: fadeIn 0.35s ease;
    }

    #projectModal.modal.active {
      align-items: stretch;
      justify-content: stretch;
    }

    #projectModal .modal-content {
      width: 100%;
      max-width: none;
      height: 100%;
      max-height: none;
      border-radius: 0;
      display: flex;
      flex-direction: column;
      box-sizing: border-box;
    }

    #projectModal .project-flow-shell {
      flex: 1;
      min-height: 0;
      padding: clamp(18px, 3vw, 40px);
      padding-top: clamp(54px, 6vw, 72px);
    }

    #projectModal .flow-steps-region {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      overflow-x: hidden;
      -webkit-overflow-scrolling: touch;
    }

    #projectModal .flow-step.active {
      padding-bottom: 8px;
    }

    #projectModal .modal-close {
      z-index: 3;
      top: clamp(10px, 2.5vw, 22px);
      right: clamp(10px, 2.5vw, 22px);
    }

    #projectModal .flow-navigation {
      flex-shrink: 0;
      padding-top: 12px;
      margin-top: auto;
      border-top: 1px solid rgba(148, 163, 184, 0.12);
      background: linear-gradient(to top, rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.65));
    }

    .modal-overlay {
      position: absolute;
      inset: 0;
      background: rgba(2, 6, 23, 0.78);
      backdrop-filter: blur(6px);
    }

    .modal-content {
      position: relative;
      background: linear-gradient(140deg, rgba(15, 23, 42, 0.95), rgba(22, 38, 67, 0.88));
      border: 1px solid rgba(56, 189, 248, 0.2);
      border-radius: 24px;
      box-shadow: 0 28px 80px rgba(2, 6, 23, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.06);
      width: 90%;
      max-width: 900px;
      max-height: 92vh;
      overflow: hidden;
      z-index: 10001;
      animation: slideUp 0.45s ease;
    }

    .project-flow-shell {
      position: relative;
      padding: 30px 34px 26px;
      min-height: 620px;
      display: flex;
      flex-direction: column;
      background:
        radial-gradient(circle at 12% 8%, rgba(56, 189, 248, 0.16), transparent 32%),
        radial-gradient(circle at 86% 14%, rgba(59, 130, 246, 0.14), transparent 36%);
    }

    .project-flow-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .wizard-back {
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(15, 23, 42, 0.45);
      color: #cbd5e1;
      border-radius: 12px;
      padding: 10px 14px;
      cursor: pointer;
      transition: all 0.2s ease;
      visibility: hidden;
    }

    .wizard-back.show {
      visibility: visible;
    }

    .wizard-back:hover {
      border-color: #38bdf8;
      color: #38bdf8;
      box-shadow: 0 0 18px rgba(56, 189, 248, 0.2);
    }

    .flow-kicker {
      color: #38bdf8;
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin: 0;
    }

    .flow-title {
      margin: 6px 0 4px;
      font-size: 32px;
      font-weight: 800;
      color: #f8fafc;
    }

    .flow-subtitle {
      margin: 0;
      color: #cbd5e1;
      font-size: 14px;
    }

    .flow-progress {
      margin: 10px 0 22px;
    }

    .flow-progress-track {
      height: 8px;
      border-radius: 999px;
      background: rgba(51, 65, 85, 0.7);
      overflow: hidden;
      border: 1px solid rgba(148, 163, 184, 0.22);
    }

    .flow-progress-fill {
      width: 16.666%;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, #0ea5e9, #38bdf8);
      box-shadow: 0 0 18px rgba(56, 189, 248, 0.6);
      transition: width 0.42s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .flow-progress-labels {
      display: flex;
      justify-content: space-between;
      gap: 4px;
      margin-top: 10px;
      color: #94a3b8;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .flow-step {
      display: none;
      animation: stepFade 0.35s ease;
      flex: 1;
      overflow-y: auto;
      padding-right: 4px;
    }

    .flow-step.active {
      display: block;
    }

    .flow-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      margin-top: 12px;
    }

    .flow-card {
      border-radius: 18px;
      border: 1px solid rgba(148, 163, 184, 0.28);
      background: rgba(15, 23, 42, 0.58);
      padding: 20px;
      cursor: pointer;
      transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease, background 0.22s ease;
    }

    .flow-card:hover {
      transform: translateY(-4px) scale(1.01);
      border-color: rgba(56, 189, 248, 0.75);
      box-shadow: 0 0 24px rgba(56, 189, 248, 0.28);
      background: rgba(56, 189, 248, 0.09);
    }

    .flow-card.selected {
      border-color: #38bdf8;
      box-shadow: 0 0 26px rgba(56, 189, 248, 0.42);
      background: rgba(56, 189, 248, 0.13);
    }

    .flow-card h3 {
      margin: 0 0 8px;
      color: #f8fafc;
      font-size: 18px;
    }

    .flow-card p {
      margin: 0;
      color: #cbd5e1;
      font-size: 13px;
      line-height: 1.45;
    }

    .skill-card {
      position: relative;
      padding-left: 44px;
    }

    .skill-card input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .skill-card::before {
      content: "";
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      border-radius: 5px;
      border: 1px solid rgba(148, 163, 184, 0.55);
      background: rgba(2, 6, 23, 0.55);
      transition: all 0.2s ease;
    }

    .skill-card.selected::before {
      border-color: #38bdf8;
      background: #38bdf8;
      box-shadow: 0 0 14px rgba(56, 189, 248, 0.55);
    }

    .details-form {
      display: grid;
      gap: 14px;
      margin-top: 8px;
    }

    .details-form label {
      display: block;
      margin-bottom: 6px;
      color: #cbd5e1;
      font-weight: 600;
      font-size: 13px;
    }

    .details-form input,
    .details-form textarea {
      width: 100%;
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(15, 23, 42, 0.52);
      color: #f8fafc;
      font-size: 14px;
      padding: 12px 14px;
      box-sizing: border-box;
      transition: all 0.22s ease;
    }

    .details-form textarea {
      min-height: 100px;
      resize: vertical;
    }

    .details-form input:focus,
    .details-form textarea:focus {
      outline: none;
      border-color: #38bdf8;
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.15), 0 0 18px rgba(56, 189, 248, 0.2);
    }

    .motive-box {
      margin-top: 12px;
    }

    .motive-box textarea {
      width: 100%;
      min-height: 170px;
      border-radius: 16px;
      border: 1px solid rgba(148, 163, 184, 0.34);
      background: rgba(15, 23, 42, 0.62);
      color: #f8fafc;
      font-size: 15px;
      line-height: 1.5;
      padding: 16px;
      box-sizing: border-box;
      transition: all 0.22s ease;
    }

    .motive-box textarea:focus {
      outline: none;
      border-color: #38bdf8;
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.14), 0 0 20px rgba(56, 189, 248, 0.28);
    }

    .quote-rotator {
      margin-top: 16px;
      padding: 14px 16px;
      border-radius: 12px;
      border: 1px solid rgba(56, 189, 248, 0.28);
      background: rgba(56, 189, 248, 0.08);
      color: #bae6fd;
      font-size: 14px;
      min-height: 24px;
      animation: quotePulse 3s ease-in-out infinite;
    }

    .complete-screen {
      position: relative;
      text-align: center;
      overflow: hidden;
      padding: 42px 12px 18px;
      min-height: 360px;
      border-radius: 20px;
      border: 1px solid rgba(56, 189, 248, 0.35);
      background: rgba(15, 23, 42, 0.5);
    }

    .complete-screen::before {
      content: "";
      position: absolute;
      inset: -20% -8%;
      background: radial-gradient(circle at center, rgba(56, 189, 248, 0.2), transparent 55%);
      pointer-events: none;
    }

    .particles {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .particle {
      position: absolute;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(56, 189, 248, 0.8);
      box-shadow: 0 0 12px rgba(56, 189, 248, 0.9);
      animation: floatParticle 7s linear infinite;
    }

    .complete-title {
      position: relative;
      z-index: 1;
      margin: 0 0 10px;
      font-size: 44px;
      color: #7dd3fc;
      text-shadow: 0 0 24px rgba(56, 189, 248, 0.55);
    }

    .complete-subtext {
      position: relative;
      z-index: 1;
      margin: 0 0 24px;
      color: #e2e8f0;
    }

    .complete-actions {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .invite-panel {
      position: relative;
      z-index: 1;
      margin-top: 28px;
      text-align: left;
      padding: 20px;
      border-radius: 16px;
      border: 1px solid rgba(56, 189, 248, 0.28);
      background: rgba(2, 6, 23, 0.55);
      max-height: 360px;
      overflow-y: auto;
    }

    .invite-panel.hidden {
      display: none;
    }

    .invite-panel h4 {
      margin: 0 0 8px;
      color: #e2e8f0;
      font-size: 16px;
    }

    .invite-panel-budget-hint {
      margin: 0 0 14px;
      font-size: 13px;
      color: #94a3b8;
    }

    .suggestion-list {
      display: grid;
      gap: 10px;
    }

    .suggestion-card {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.25);
      background: rgba(15, 23, 42, 0.65);
    }

    .suggestion-card strong {
      color: #f8fafc;
      font-size: 14px;
    }

    .suggestion-meta {
      font-size: 12px;
      color: #94a3b8;
      margin-top: 6px;
    }

    .invite-match-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }

    .invite-match-pill {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.04em;
      color: #082f49;
      background: linear-gradient(135deg, #bae6fd, #38bdf8);
      padding: 6px 10px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .invite-match-pill.loose {
      background: rgba(148, 163, 184, 0.35);
      color: #e2e8f0;
    }

    .wizard-join-matches-intro {
      margin: 0 0 14px;
      color: #cbd5e1;
      font-size: 14px;
      line-height: 1.5;
    }

    .wizard-join-expect {
      margin-bottom: 18px;
    }

    .wizard-join-expect label {
      display: block;
      margin-bottom: 6px;
      color: #cbd5e1;
      font-weight: 600;
      font-size: 13px;
    }

    .wizard-join-expect input {
      max-width: 220px;
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(15, 23, 42, 0.52);
      color: #f8fafc;
      font-size: 14px;
      padding: 10px 12px;
    }

    #joinMatchProjectList {
      margin-bottom: 20px;
    }

    #wizardJoinDashboardBtn {
      width: 100%;
      margin-top: 8px;
    }

    .flow-btn {
      border: none;
      border-radius: 12px;
      padding: 12px 18px;
      cursor: pointer;
      font-weight: 700;
      transition: all 0.2s ease;
    }

    .flow-btn.primary {
      color: #082f49;
      background: linear-gradient(135deg, #7dd3fc, #38bdf8);
      box-shadow: 0 12px 24px rgba(56, 189, 248, 0.34);
    }

    .flow-btn.secondary {
      color: #cbd5e1;
      border: 1px solid rgba(148, 163, 184, 0.45);
      background: rgba(15, 23, 42, 0.5);
    }

    .flow-btn:hover {
      transform: translateY(-2px);
    }

    .flow-navigation {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 18px;
      gap: 12px;
    }

    .flow-error {
      min-height: 20px;
      color: #fda4af;
      font-size: 13px;
    }

    @keyframes stepFade {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes quotePulse {
      0%, 100% { opacity: 0.65; }
      50% { opacity: 1; }
    }

    @keyframes floatParticle {
      0% { transform: translateY(110%) scale(0.6); opacity: 0; }
      15% { opacity: 1; }
      100% { transform: translateY(-18%) scale(1.25); opacity: 0; }
    }

    /* =======================
       DASHBOARD CORE
    ======================= */
    .dashboard-root {
      display: none;
      min-height: 100vh;
      background: #0f172a;
      color: #f8fafc;
    }

    .dashboard-root.active {
      display: block;
    }

    .dashboard-shell {
      display: grid;
      grid-template-columns: 250px 1fr 310px;
      grid-template-rows: auto 1fr;
      min-height: 100vh;
      gap: 14px;
      padding: 14px;
      box-sizing: border-box;
    }

    .dashboard-topbar {
      grid-column: 1 / 4;
      background: rgba(30, 41, 59, 0.7);
      border: 1px solid rgba(56, 189, 248, 0.15);
      border-radius: 14px;
      backdrop-filter: blur(10px);
      box-shadow: 0 12px 32px rgba(2, 6, 23, 0.45);
      padding: 14px 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
    }

    .dashboard-topbar h3 {
      margin: 0;
      font-size: 20px;
      color: #7dd3fc;
    }

    .dashboard-topbar .topbar-search {
      flex: 1;
      max-width: 460px;
      margin: 0 14px;
    }

    .dashboard-topbar input {
      width: 100%;
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(15, 23, 42, 0.7);
      border-radius: 12px;
      padding: 10px 12px;
      color: #e2e8f0;
      box-sizing: border-box;
    }

    .dashboard-topbar input:focus {
      outline: none;
      border-color: #38bdf8;
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.14);
    }

    .dashboard-top-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .dashboard-pill-btn {
      border: 1px solid rgba(148, 163, 184, 0.3);
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.65);
      color: #cbd5e1;
      padding: 9px 12px;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .dashboard-pill-btn:hover {
      border-color: #38bdf8;
      color: #38bdf8;
      transform: translateY(-1px);
    }

    .dashboard-sidebar {
      background: rgba(30, 41, 59, 0.62);
      border: 1px solid rgba(56, 189, 248, 0.15);
      border-radius: 14px;
      backdrop-filter: blur(8px);
      padding: 14px;
      box-shadow: 0 10px 26px rgba(2, 6, 23, 0.42);
    }

    .dashboard-nav {
      display: grid;
      gap: 8px;
    }

    .dashboard-nav button {
      border: 1px solid transparent;
      border-radius: 10px;
      padding: 11px 12px;
      text-align: left;
      cursor: pointer;
      color: #cbd5e1;
      background: rgba(15, 23, 42, 0.45);
      transition: all 0.2s ease;
    }

    .dashboard-nav button:hover,
    .dashboard-nav button.active {
      border-color: rgba(56, 189, 248, 0.5);
      background: rgba(56, 189, 248, 0.14);
      color: #7dd3fc;
    }

    .dashboard-main {
      background: rgba(30, 41, 59, 0.58);
      border: 1px solid rgba(56, 189, 248, 0.14);
      border-radius: 14px;
      padding: 14px;
      overflow-y: auto;
      box-shadow: 0 10px 24px rgba(2, 6, 23, 0.36);
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .dashboard-right {
      background: rgba(30, 41, 59, 0.58);
      border: 1px solid rgba(56, 189, 248, 0.14);
      border-radius: 14px;
      padding: 14px;
      overflow-y: auto;
      box-shadow: 0 10px 24px rgba(2, 6, 23, 0.36);
      display: grid;
      gap: 12px;
      align-content: start;
    }

    .dashboard-card {
      background: rgba(15, 23, 42, 0.64);
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 14px;
      padding: 14px;
      transition: all 0.2s ease;
    }

    .dashboard-card:hover {
      border-color: rgba(56, 189, 248, 0.4);
      box-shadow: 0 10px 24px rgba(56, 189, 248, 0.1);
    }

    .dashboard-card h4 {
      margin: 0 0 10px;
      color: #7dd3fc;
      font-size: 15px;
    }

    .progress-track {
      height: 8px;
      border-radius: 999px;
      background: rgba(51, 65, 85, 0.75);
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #0ea5e9, #38bdf8);
      box-shadow: 0 0 12px rgba(56, 189, 248, 0.6);
    }

    .mini-grid {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }

    .tag-chip {
      border-radius: 10px;
      border: 1px solid rgba(148, 163, 184, 0.28);
      background: rgba(15, 23, 42, 0.5);
      padding: 8px 10px;
      color: #cbd5e1;
      font-size: 13px;
    }

    .board-columns {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .board-col {
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.2);
      background: rgba(15, 23, 42, 0.5);
      padding: 10px;
      min-height: 130px;
    }

    .board-col h5 {
      margin: 0 0 8px;
      color: #cbd5e1;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .task-item {
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 10px;
      padding: 8px;
      margin-bottom: 6px;
      background: rgba(30, 41, 59, 0.6);
      font-size: 13px;
      color: #e2e8f0;
    }

    .dashboard-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }

    .chat-log {
      max-height: 130px;
      overflow-y: auto;
      display: grid;
      gap: 6px;
      margin-bottom: 8px;
    }

    .chat-msg {
      padding: 7px 9px;
      border-radius: 10px;
      background: rgba(30, 41, 59, 0.72);
      color: #e2e8f0;
      font-size: 13px;
    }

    .inline-form {
      display: flex;
      gap: 8px;
    }

    .inline-form input {
      flex: 1;
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(15, 23, 42, 0.75);
      border-radius: 10px;
      color: #e2e8f0;
      padding: 9px 10px;
    }

    .inline-form button {
      border: none;
      border-radius: 10px;
      background: linear-gradient(135deg, #38bdf8, #0ea5e9);
      color: #082f49;
      font-weight: 700;
      padding: 9px 12px;
      cursor: pointer;
    }

    .notif-pop {
      position: fixed;
      bottom: 22px;
      right: 22px;
      background: rgba(30, 41, 59, 0.92);
      border: 1px solid rgba(56, 189, 248, 0.5);
      border-radius: 12px;
      color: #e2e8f0;
      padding: 12px 14px;
      box-shadow: 0 14px 28px rgba(2, 6, 23, 0.55);
      z-index: 11000;
      animation: fadeIn 0.25s ease;
    }

    .member-main-wrap {
      width: 100%;
      min-height: 100vh;
      padding: 14px;
      box-sizing: border-box;
    }

    .member-topbar {
      width: 100%;
      margin-bottom: 12px;
    }

    .member-tabbar {
      width: 100%;
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-bottom: 12px;
      flex-wrap: wrap;
    }

    .member-tab-btn {
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(30, 41, 59, 0.65);
      color: #cbd5e1;
      border-radius: 999px;
      padding: 9px 18px;
      cursor: pointer;
      transition: all 0.2s ease;
      min-width: 110px;
    }

    .member-tab-btn.active {
      border-color: #38bdf8;
      color: #7dd3fc;
      background: rgba(56, 189, 248, 0.15);
      box-shadow: 0 0 18px rgba(56, 189, 248, 0.35);
    }

    .member-content {
      width: 100%;
      display: grid;
      gap: 12px;
    }

    .feed-post {
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.62);
      padding: 12px;
      margin-bottom: 10px;
    }

    .post-image-wrap {
      margin-top: 10px;
      border: 1px solid rgba(148, 163, 184, 0.24);
      border-radius: 12px;
      overflow: hidden;
      background: rgba(30, 41, 59, 0.65);
    }

    .post-image-wrap img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      display: block;
    }

    .post-image-meta {
      padding: 10px;
      border-top: 1px solid rgba(148, 163, 184, 0.18);
    }

    .feed-post-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }

    .feed-author {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .feed-avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: rgba(56, 189, 248, 0.2);
      border: 1px solid rgba(56, 189, 248, 0.45);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #7dd3fc;
      font-size: 12px;
      font-weight: 700;
    }

    .feed-actions {
      display: flex;
      gap: 8px;
      margin-top: 8px;
    }

    .post-comments {
      margin-top: 8px;
      display: grid;
      gap: 6px;
    }

    .post-comment-item {
      font-size: 12px;
      color: #cbd5e1;
      background: rgba(30, 41, 59, 0.5);
      border-radius: 9px;
      padding: 6px 8px;
    }

    .recommend-row {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(220px, 1fr);
      gap: 10px;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .recommend-card {
      border-radius: 12px;
      border: 1px solid rgba(56, 189, 248, 0.35);
      background: rgba(30, 41, 59, 0.7);
      padding: 10px;
    }

    .member-top-icons {
      display: flex;
      gap: 8px;
      align-items: center;
      position: relative;
    }

    .icon-btn {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(148, 163, 184, 0.34);
      background: rgba(15, 23, 42, 0.62);
      color: #e2e8f0;
      cursor: pointer;
      position: relative;
    }

    .icon-badge {
      position: absolute;
      right: -3px;
      top: -3px;
      background: #38bdf8;
      color: #082f49;
      font-size: 10px;
      font-weight: 700;
      border-radius: 999px;
      padding: 2px 5px;
    }

    .dropdown-panel {
      position: absolute;
      right: 0;
      top: 46px;
      width: 290px;
      max-height: 320px;
      overflow-y: auto;
      z-index: 11010;
      background: rgba(30, 41, 59, 0.96);
      border: 1px solid rgba(56, 189, 248, 0.35);
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(2, 6, 23, 0.6);
      padding: 10px;
      display: none;
    }

    .dropdown-panel.show {
      display: block;
    }

    /* ================= AUTH MODAL ================= */
    .auth-modal {
      max-width: 500px;
    }

    .auth-tabs {
      display: flex;
      margin-bottom: 24px;
      border-bottom: 1px solid #334155;
    }

    .auth-tab {
      flex: 1;
      padding: 12px 0;
      background: transparent;
      border: none;
      color: #94a3b8;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      border-bottom: 2px solid transparent;
    }

    .auth-tab.active {
      color: #38bdf8;
      border-bottom-color: #38bdf8;
    }

    .auth-tab:hover {
      color: #cbd5e1;
    }

    .auth-form {
      display: none;
    }

    .auth-form.active {
      display: block;
    }

    .auth-message {
      margin: 0 0 18px;
      color: #94a3b8;
      font-size: 14px;
      padding: 12px 16px;
      background: rgba(15, 23, 42, 0.65);
      border: 1px solid rgba(56, 189, 248, 0.15);
      border-radius: 12px;
      text-align: center;
    }

    .otp-section {
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid #334155;
    }

    .otp-section input {
      text-align: center;
      font-size: 18px;
      letter-spacing: 4px;
    }


    .modal-close {
      position: absolute;
      top: 16px;
      right: 16px;
      background: transparent;
      border: none;
      color: #94a3b8;
      font-size: 28px;
      cursor: pointer;
      transition: color 0.2s ease;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-close:hover {
      color: #38bdf8;
    }

    .modal-title {
      margin: 0 0 8px;
      font-size: 28px;
      font-weight: 800;
      color: #38bdf8;
      text-align: center;
    }

    .modal-subtitle {
      margin: 0 0 24px;
      font-size: 14px;
      color: #cbd5e1;
      text-align: center;
    }

    .form-section {
      margin-bottom: 24px;
    }

    .form-section h3 {
      margin: 0 0 14px;
      font-size: 16px;
      font-weight: 700;
      color: #e2e8f0;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      margin-bottom: 14px;
    }

    .form-group label {
      font-size: 14px;
      font-weight: 600;
      color: #cbd5e1;
      margin-bottom: 8px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: 12px 14px;
      border: 1px solid #334155;
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.6);
      color: white;
      font-family: inherit;
      font-size: 14px;
      transition: all 0.2s ease;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #38bdf8;
      background: rgba(15, 23, 42, 0.8);
      box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.1);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 100px;
    }

    .checkbox-group {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      min-height: 120px;
      opacity: 1;
      transition: opacity 0.25s ease;
    }

    .checkbox-group.fade-out {
      opacity: 0;
    }

    .checkbox-label {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      padding: 10px 12px;
      border-radius: 8px;
      border: 1px solid #334155;
      transition: all 0.2s ease;
      background: rgba(15, 23, 42, 0.4);
    }

    .role-placeholder {
      grid-column: 1 / -1;
      padding: 20px;
      border-radius: 14px;
      border: 1px dashed rgba(148, 163, 184, 0.45);
      background: rgba(30, 41, 59, 0.45);
      color: #94a3b8;
      font-size: 14px;
      text-align: center;
    }

    .checkbox-label:hover {
      border-color: #38bdf8;
      background: rgba(56, 189, 248, 0.1);
    }

    .checkbox-label input[type="checkbox"] {
      width: 18px;
      height: 18px;
      cursor: pointer;
      accent-color: #38bdf8;
    }

    .checkbox-label span {
      font-size: 13px;
      color: #cbd5e1;
      font-weight: 500;
    }

    .radio-group {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }

    .radio-label {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      padding: 8px 12px;
      border-radius: 8px;
      transition: all 0.2s ease;
    }

    .radio-label:hover {
      background: rgba(56, 189, 248, 0.1);
    }

    .radio-label input[type="radio"] {
      width: 18px;
      height: 18px;
      cursor: pointer;
      accent-color: #38bdf8;
    }

    .radio-label span {
      font-size: 14px;
      color: #cbd5e1;
      font-weight: 500;
    }

    .submit-btn {
      width: 100%;
      padding: 14px 24px;
      background: linear-gradient(135deg, #38bdf8, #0ea5e9);
      border: none;
      border-radius: 10px;
      color: #0f172a;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-top: 12px;
    }

    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(56, 189, 248, 0.4);
    }

    .submit-btn:active {
      transform: translateY(0);
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes slideUp {
      from {
        transform: translateY(30px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    /* MOBILE RESPONSIVE */
    @media (max-width: 768px) {
      .dashboard-shell {
        grid-template-columns: 1fr;
        grid-template-rows: auto auto auto auto;
      }

      .dashboard-topbar {
        grid-column: 1;
        flex-wrap: wrap;
      }

      .dashboard-topbar .topbar-search {
        order: 3;
        flex-basis: 100%;
        margin: 0;
      }

      .board-columns {
        grid-template-columns: 1fr;
      }

      .dashboard-sidebar {
        display: none;
      }

      .member-tabbar {
        justify-content: flex-start;
      }

      #projectModal .project-flow-shell {
        min-height: 100vh;
        padding: 16px 16px 20px;
        padding-top: 52px;
      }

      .project-flow-shell {
        padding: 22px 20px 18px;
        min-height: 82vh;
      }

      .flow-title {
        font-size: 25px;
      }

      .flow-progress-labels {
        font-size: 9px;
      }

      .flow-grid {
        grid-template-columns: 1fr;
      }

      .complete-title {
        font-size: 34px;
      }
    }
  </style>
</head>

<body>

<!-- ================= SPLASH SCREEN ================= -->
<div id="splash">

  <div class="scene">
    <div class="brand-title">MAKE BIG</div>

    <div class="stick-word">
      <div class="stick-letter letter-m">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
      </div>
      <div class="stick-letter letter-a">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
      </div>
      <div class="stick-letter letter-k">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
      </div>
      <div class="stick-letter letter-e">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
      </div>
      <div class="stick-letter letter-b">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
      </div>
      <div class="stick-letter letter-i">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
      </div>
      <div class="stick-letter letter-g">
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
        <div class="bar"></div>
      </div>
    </div>
    <div class="brand-subtitle">Build big ideas together</div>
    <div class="light"></div>
    <div class="table"></div>

    <!-- COMBINED CENTRAL STICK FIGURE -->
    <div class="person center">
      <div class="head"></div>
      <div class="body"></div>
      <div class="arm left"></div>
      <div class="arm right"></div>
    </div>

    <!-- HANDSHAKE -->
    <div class="handshake"></div>

    <!-- TEA / COFFEE -->
    <div class="cup cup1"></div>
    <div class="cup cup2"></div>

  </div>

  <div class="loading-text">
    Build the future with every stick.
  </div>

</div>

<!-- ================= MAIN WEBSITE ================= -->

<div class="navbar">
  <div class="nav-left">
    <div id="profileContainer" class="profile hidden" onclick="toggleProfileMenu()">
      <div class="avatar" id="avatar">U</div>
    </div>
    <div class="logo">Make Big</div>
    <div id="profileMenu" class="profile-menu" onclick="event.stopPropagation()">
      <p id="userName"></p>
      <p id="userContact"></p>
      <button type="button" onclick="openEditProfile()">Edit Profile</button>
      <button type="button" class="logout-btn" onclick="logout()">Logout</button>
    </div>
  </div>
  <div class="nav-links">
    <a href="#">Home</a>
    <a href="#">Explore</a>
    <a href="#" id="navProjectsLink">Projects</a>
    <div id="authSection">
      <a href="javascript:void(0)" id="loginBtn" class="auth-btn" onclick="openAuth()">Login</a>
    </div>
  </div>
</div>

<div class="hero">
  <h1>Build Big Ideas Together</h1>
  <p>Connect developers, filmmakers, writers, musicians & creators</p>
  <button class="btn" id="startProjectBtn" onclick="handleStartProject()">Start a Project</button>
</div>

<div class="skills">
  <h2>All Creative Fields in One Place</h2>

  <div class="grid">
    <div class="card"><h3>Web & Software</h3></div>
    <div class="card"><h3>Filmmaking</h3></div>
    <div class="card"><h3>Literature</h3></div>
    <div class="card"><h3>Music</h3></div>
    <div class="card"><h3>Content Creation</h3></div>
    <div class="card"><h3>Design & Art</h3></div>
    <div class="card"><h3>Game Development</h3></div>
  </div>
</div>

<div class="footer">
  © 2026 Make Big — Built for creators
</div>

<div id="dashboardRoot" class="dashboard-root"></div>

<!-- ================= PROJECT MODAL ================= -->
<div id="projectModal" class="modal">
  <div class="modal-overlay" onclick="closeProjectModal()"></div>
  <div class="modal-content project-flow-modal-inner">
    <button class="modal-close" onclick="closeProjectModal()">✕</button>
    <div class="project-flow-shell">
      <div class="project-flow-header">
        <button id="wizardBack" class="wizard-back" type="button" onclick="wizardPrev()">← Back</button>
        <div>
          <p class="flow-kicker">Make Big Creation Flow</p>
          <h2 id="wizardTitle" class="flow-title">Choose your path</h2>
          <p id="wizardSubtitle" class="flow-subtitle">Select how you want to begin.</p>
        </div>
      </div>

      <div class="flow-progress">
        <div class="flow-progress-track">
          <div id="wizardProgressFill" class="flow-progress-fill"></div>
        </div>
        <div class="flow-progress-labels">
          <span>Step 1</span>
          <span>Step 2</span>
          <span>Step 3</span>
          <span>Step 4</span>
          <span>Step 5</span>
          <span>Complete</span>
        </div>
      </div>

      <div class="flow-steps-region">

      <div id="wizardStep1" class="flow-step active">
        <div class="flow-grid" style="grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));">
          <div class="flow-card" onclick="selectEntry('create')">
            <h3>Create Project</h3>
            <p>Start your own project and build your dream team.</p>
          </div>
          <div class="flow-card" onclick="selectEntry('join')">
            <h3>Join Project</h3>
            <p>Find projects that need your skills and collaborate.</p>
          </div>
        </div>
      </div>

      <div id="wizardStep2" class="flow-step">
        <div id="categoryGrid" class="flow-grid"></div>
      </div>

      <div id="wizardStep3" class="flow-step">
        <div id="skillGrid" class="flow-grid"></div>
      </div>

      <div id="wizardStep4" class="flow-step">
        <div class="details-form">
          <div>
            <label for="wizardProjectName">Project Name</label>
            <input id="wizardProjectName" type="text" placeholder="Neon Dream Studio Platform">
          </div>
          <div>
            <label for="wizardShortDesc">Short Description</label>
            <textarea id="wizardShortDesc" placeholder="Describe your project in one punchy paragraph."></textarea>
          </div>
          <div id="wizardTeamSizeRow">
            <label for="wizardTeamSize">Team Size Needed</label>
            <input id="wizardTeamSize" type="number" min="1" max="100" placeholder="6">
          </div>
          <div>
            <label for="wizardDeadline">Deadline</label>
            <input id="wizardDeadline" type="date">
          </div>
          <div>
            <label for="wizardCoverImage">Upload Cover Image</label>
            <input id="wizardCoverImage" type="file" accept="image/*">
          </div>
        </div>
      </div>

      <div id="wizardStep5" class="flow-step">
        <div class="motive-box">
          <label id="wizardMotiveLabel" for="wizardVision" style="display:block;margin-bottom:8px;color:#cbd5e1;font-weight:700;">What is your vision for this project?</label>
          <textarea id="wizardVision" placeholder="We want to create a short sci-fi film that explores dreams and reality."></textarea>
          <div id="quoteRotator" class="quote-rotator"></div>
        </div>
      </div>

      <div id="wizardStep6" class="flow-step">
        <div id="wizardCreateBudget" class="salary-form">
          <h3>Budget & Compensation</h3>
          <p>Set the salary range you can offer for team members.</p>
          <div>
            <label for="wizardMinSalary">Minimum Salary (per month)</label>
            <input id="wizardMinSalary" type="number" placeholder="5000" min="0">
          </div>
          <div>
            <label for="wizardMaxSalary">Maximum Salary (per month)</label>
            <input id="wizardMaxSalary" type="number" placeholder="15000" min="0">
          </div>
          <div>
            <label for="wizardCurrency">Currency</label>
            <select id="wizardCurrency">
              <option value="USD">USD</option>
              <option value="EUR">EUR</option>
              <option value="INR">INR</option>
              <option value="GBP">GBP</option>
            </select>
          </div>
        </div>

        <div id="wizardJoinMatches" style="display: none;">
          <p class="wizard-join-matches-intro">These open roles are ranked for your chosen category and skills. Add an expected monthly amount to prioritize pay-aligned teams.</p>
          <div class="wizard-join-expect">
            <label for="wizardJoinExpectSalary">Expected monthly compensation (optional)</label>
            <input id="wizardJoinExpectSalary" type="number" min="0" placeholder="e.g. 8500">
          </div>
          <div id="joinMatchProjectList" class="flow-grid"></div>
          <button type="button" id="wizardJoinDashboardBtn" class="flow-btn primary" onclick="enterDashboard()">Continue to dashboard</button>
        </div>
      </div>

      <div id="wizardStep7" class="flow-step">
        <div class="complete-screen">
          <div class="particles" id="wizardParticles"></div>
          <h3 id="wizardCompleteTitle" class="complete-title">Your project is ready.</h3>
          <p id="wizardCompleteSubtext" class="complete-subtext">Start building with creators around the world.</p>
          <div class="complete-actions">
            <button id="wizardPrimaryAction" class="flow-btn primary" type="button" onclick="enterDashboard()">Enter Dashboard</button>
            <button id="wizardSecondaryAction" class="flow-btn secondary" type="button" onclick="inviteMembers()">Invite people</button>
          </div>
          <div id="inviteMembersPanel" class="invite-panel hidden">
            <h4 id="invitePanelHeading">Suggested people for your stack</h4>
            <p id="inviteBudgetHint" class="invite-panel-budget-hint"></p>
            <p id="inviteContextLine" class="invite-panel-budget-hint" style="margin-top:-6px;"></p>
            <div id="invitePeopleList" class="suggestion-list"></div>
          </div>
        </div>
      </div>

      </div>

      <div class="flow-navigation">
        <span id="wizardError" class="flow-error"></span>
        <button id="wizardNextBtn" class="flow-btn primary" type="button" onclick="wizardNext()">Next</button>
      </div>
    </div>
  </div>
</div>

<!-- ================= AUTH MODAL ================= -->
<div id="authModal" class="modal">
  <div class="modal-overlay" onclick="closeAuthModal()"></div>
  <div class="modal-content auth-modal">
    <button class="modal-close" onclick="closeAuthModal()">✕</button>

    <div class="auth-tabs">
      <button class="auth-tab active" onclick="switchTab('signin')">Sign In</button>
      <button class="auth-tab" onclick="switchTab('signup')">Sign Up</button>
    </div>
    <div id="authMessage" class="auth-message">Login to access project creation.</div>

    <!-- SIGN IN FORM -->
    <div id="signinForm" class="auth-form active">
      <h2 class="modal-title">Welcome Back</h2>
      <p class="modal-subtitle">Sign in to your account</p>

      <form id="signinFormEl">
        <div class="form-group">
          <label for="signinContact">Email or Phone</label>
          <input type="text" id="signinContact" placeholder="Enter email or phone" required>
        </div>

        <button type="button" class="submit-btn" onclick="sendOTP('signin')">Send OTP</button>

        <div id="signinOTPSection" class="otp-section" style="display: none;">
          <div class="form-group">
            <label for="signinOTP">Enter OTP</label>
            <input type="text" id="signinOTP" placeholder="6-digit code" maxlength="6" required>
          </div>
          <button type="submit" class="submit-btn">Verify & Sign In</button>
        </div>
      </form>
    </div>

    <!-- SIGN UP FORM -->
    <div id="signupForm" class="auth-form">
      <h2 class="modal-title">Create Account</h2>
      <p class="modal-subtitle">Join the Make Big community</p>

      <form id="signupFormEl">
        <div class="form-group">
          <label for="signupName">Full Name</label>
          <input type="text" id="signupName" placeholder="Enter your name" required>
        </div>

        <div class="form-group">
          <label>Contact Method</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="contactType" value="email" checked>
              <span>Email</span>
            </label>
            <label class="radio-label">
              <input type="radio" name="contactType" value="phone">
              <span>Phone</span>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label for="signupContact">Email or Phone</label>
          <input type="text" id="signupContact" placeholder="Enter email or phone" required>
        </div>

        <div class="form-group">
          <label for="signupSkills">Your Skills (comma separated)</label>
          <input type="text" id="signupSkills" placeholder="e.g. Frontend Development, UI Design, Video Editing">
        </div>

        <div class="form-group">
          <label for="signupHobbies">Your Hobbies (comma separated)</label>
          <input type="text" id="signupHobbies" placeholder="e.g. Photography, Gaming, Music Production">
        </div>

        <button type="button" class="submit-btn" onclick="sendOTP('signup')">Send OTP</button>

        <div id="signupOTPSection" class="otp-section" style="display: none;">
          <div class="form-group">
            <label for="signupOTP">Enter OTP</label>
            <input type="text" id="signupOTP" placeholder="6-digit code" maxlength="6" required>
          </div>
          <button type="submit" class="submit-btn">Verify & Create Account</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ================= EDIT PROFILE MODAL ================= -->
<div id="editProfileModal" class="modal edit-profile-modal">
  <div class="modal-overlay" onclick="closeEditProfile()"></div>
  <div class="modal-content">
    <button class="modal-close" onclick="closeEditProfile()">✕</button>
    <h2 class="modal-title">Edit Profile</h2>
    <p class="modal-subtitle">Update your profile (this powers matching + invites)</p>
    <form id="editProfileForm">
      <div class="form-group">
        <label for="editName">Name</label>
        <input type="text" id="editName" placeholder="Your name" required>
      </div>
      <div class="form-group">
        <label for="editContact">Email or Phone</label>
        <input type="text" id="editContact" placeholder="Your contact" required>
      </div>
      <div class="form-group">
        <label for="editRole">Profile type</label>
        <select id="editRole">
          <option value="member">I want to join projects</option>
          <option value="creator">I create projects</option>
          <option value="both">Both</option>
        </select>
      </div>
      <div class="form-group">
        <label for="editTagline">Tagline</label>
        <input type="text" id="editTagline" placeholder="Short one-liner (ex: Full-stack dev building SaaS)">
      </div>
      <div class="form-group">
        <label for="editCategoryIds">Categories (comma separated ids)</label>
        <input type="text" id="editCategoryIds" placeholder="web, mobile, ai">
      </div>
      <div class="form-group">
        <label for="editSkills">Skills / Roles (comma separated)</label>
        <input type="text" id="editSkills" placeholder="Frontend Developer, UI/UX Designer">
      </div>
      <div class="form-group">
        <label for="editHobbies">Hobbies / Interests (comma separated)</label>
        <input type="text" id="editHobbies" placeholder="Photography, Gaming, Music Production">
      </div>
      <div class="form-group">
        <label style="display:flex;align-items:center;gap:10px;">
          <input type="checkbox" id="editAvailableForInvites">
          <span>Show me in Invite People (available for invites)</span>
        </label>
      </div>
      <div class="form-group">
        <label for="editRateMin">My expected monthly (min)</label>
        <input type="number" id="editRateMin" min="0" placeholder="5000">
      </div>
      <div class="form-group">
        <label for="editRateMax">My expected monthly (max)</label>
        <input type="number" id="editRateMax" min="0" placeholder="12000">
      </div>
      <div class="form-group">
        <label for="editRateCurrency">Currency</label>
        <select id="editRateCurrency">
          <option value="USD">USD</option>
          <option value="EUR">EUR</option>
          <option value="INR">INR</option>
          <option value="GBP">GBP</option>
        </select>
      </div>
      <button type="submit" class="submit-btn">Save</button>
      <button type="button" class="cancel-btn" onclick="closeEditProfile()">Cancel</button>
    </form>
  </div>
</div>

<!-- SPLASH REMOVE -->
<script>
  function hideSplash() {
    document.getElementById("splash").style.display = "none";
  }

  // ================= AUTHENTICATION SYSTEM =================
  let currentOTP = null;
  let currentUser = null;
  const appState = {
    user: null,
    role: null,
    currentProject: null,
    view: "home",
    activeTab: "home",
    posts: [],
    projects: [],
    people: [],
    notifications: [],
    recommendations: []
  };

  function checkAuth() {
    const user = JSON.parse(localStorage.getItem('user'));
    if (user && user.isLoggedIn) {
      currentUser = user;
      appState.user = user;
      hydrateActiveProjectFromStorage();
      updateUIForLoggedIn(user);
      return true;
    }
    appState.user = null;
    updateUIForLoggedOut();
    return false;
  }

  function updateUIForLoggedIn(user) {
    const authSection = document.getElementById('authSection');
    authSection.innerHTML = '';
    document.getElementById('profileContainer').classList.remove('hidden');
    loadUserProfile(user);
    appState.user = user;
    document.getElementById('startProjectBtn').textContent = 'Start a Project';
    document.getElementById('startProjectBtn').style.opacity = '1';
  }

  function setAuthMessage(message) {
    const messageEl = document.getElementById('authMessage');
    if (messageEl) {
      messageEl.textContent = message;
    }
  }

  function updateUIForLoggedOut(message = 'Login to access project creation.') {
    const authSection = document.getElementById('authSection');
    authSection.innerHTML = '<a href="javascript:void(0)" id="loginBtn" class="auth-btn" onclick="openAuth()">Login</a>';
    document.getElementById('profileContainer').classList.add('hidden');
    document.getElementById('profileMenu').classList.remove('active');
    document.getElementById('startProjectBtn').textContent = 'Login to Start a Project';
    document.getElementById('startProjectBtn').style.opacity = '0.6';
    setAuthMessage(message);
  }

  function openAuth() {
    const modal = document.getElementById('authModal');
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
    switchTab('signin');
  }

  function toggleProfileMenu() {
    const profileMenu = document.getElementById('profileMenu');
    profileMenu.classList.toggle('active');
  }

  function loadUserProfile(user) {
    if (!user) return;
    document.getElementById('userName').textContent = user.name;
    document.getElementById('userContact').textContent = user.contact;
    document.getElementById('avatar').textContent = user.name.trim().charAt(0).toUpperCase() || 'U';
  }

  function openEditProfile() {
    const modal = document.getElementById('editProfileModal');
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
    const user = JSON.parse(localStorage.getItem('user')) || {};
    document.getElementById('editName').value = user.name || '';
    document.getElementById('editContact').value = user.contact || '';
    document.getElementById('editSkills').value = (user.skills || []).join(', ');
    document.getElementById('editHobbies').value = (user.hobbies || []).join(', ');
    // Load backend profile (if server running), otherwise from local cache
    const cached = JSON.parse(localStorage.getItem("makeBigProfile") || "null");
    const applyProfileToForm = (profile) => {
      if (!profile) return;
      document.getElementById("editRole").value = profile.role || "member";
      document.getElementById("editTagline").value = profile.tagline || "";
      document.getElementById("editCategoryIds").value = (profile.categoryIds || []).join(", ");
      document.getElementById("editSkills").value = (profile.skills || (user.skills || [])).join(", ");
      document.getElementById("editAvailableForInvites").checked = Boolean(profile.availableForInvites);
      document.getElementById("editRateMin").value = profile.rateMin ?? "";
      document.getElementById("editRateMax").value = profile.rateMax ?? "";
      document.getElementById("editRateCurrency").value = profile.currency || "USD";
    };
    if (cached && cached.contact && cached.contact.toLowerCase() === (user.contact || "").toLowerCase()) {
      applyProfileToForm(cached);
    }
    const contact = user.contact || "";
    if (contact) {
      fetch(`/api/profile?contact=${encodeURIComponent(contact)}`)
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          if (data && data.profile) applyProfileToForm(data.profile);
        })
        .catch(() => {});
    }
  }

  function closeEditProfile() {
    const modal = document.getElementById('editProfileModal');
    modal.classList.remove('active');
    document.body.style.overflow = 'auto';
  }

  function saveProfile(event) {
    event.preventDefault();
    const name = document.getElementById('editName').value.trim();
    const contact = document.getElementById('editContact').value.trim();
    if (!name || !contact) {
      alert('Please fill in both fields.');
      return;
    }
    const user = { name, contact, isLoggedIn: true, skills: (document.getElementById('editSkills').value || '').split(',').map(s => s.trim()).filter(Boolean), hobbies: (document.getElementById('editHobbies').value || '').split(',').map(h => h.trim()).filter(Boolean) };
    localStorage.setItem('user', JSON.stringify(user));
    loadUserProfile(user);
    updateUIForLoggedIn(user);
    const profile = {
      contact,
      role: document.getElementById("editRole").value,
      tagline: document.getElementById("editTagline").value.trim(),
      categoryIds: document.getElementById("editCategoryIds").value.split(",").map(s => s.trim()).filter(Boolean),
      skills: document.getElementById("editSkills").value.split(",").map(s => s.trim()).filter(Boolean),
      availableForInvites: document.getElementById("editAvailableForInvites").checked,
      rateMin: document.getElementById("editRateMin").value === "" ? "" : parseInt(document.getElementById("editRateMin").value, 10),
      rateMax: document.getElementById("editRateMax").value === "" ? "" : parseInt(document.getElementById("editRateMax").value, 10),
      currency: document.getElementById("editRateCurrency").value
    };
    localStorage.setItem("makeBigProfile", JSON.stringify(profile));
    fetch("/api/profile/upsert", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(profile)
    }).then(() => apiGetSeed()).catch(() => {});
    closeEditProfile();
  }

  function closeAuthModal() {
    const modal = document.getElementById('authModal');
    modal.classList.remove('active');
    document.body.style.overflow = 'auto';
    document.getElementById('signinFormEl').reset();
    document.getElementById('signupFormEl').reset();
    document.getElementById('signinOTPSection').style.display = 'none';
    document.getElementById('signupOTPSection').style.display = 'none';
    setAuthMessage('Login to access project creation.');
  }

  function closeAuth() {
    closeAuthModal();
  }

  function switchTab(tab) {
    const tabs = document.querySelectorAll('.auth-tab');
    const forms = document.querySelectorAll('.auth-form');

    tabs.forEach(t => t.classList.remove('active'));
    forms.forEach(f => f.classList.remove('active'));

    document.querySelector(`[onclick="switchTab('${tab}')"]`).classList.add('active');
    document.getElementById(`${tab}Form`).classList.add('active');
  }

  function generateOTP() {
    return Math.floor(100000 + Math.random() * 900000).toString();
  }

  function sendOTP(type) {
    const contact = document.getElementById(`${type}Contact`).value;
    if (!contact) {
      alert('Please enter your email or phone');
      return;
    }

    currentOTP = generateOTP();
    alert(`OTP sent to ${contact}: ${currentOTP}`); // Simulation for testing

    document.getElementById(`${type}OTPSection`).style.display = 'block';
    setAuthMessage('Enter the OTP sent to your contact.');
  }

  function verifyOTP(type) {
    const enteredOTP = document.getElementById(`${type}OTP`).value;
    if (enteredOTP !== currentOTP) {
      alert('Invalid OTP. Please try again.');
      return false;
    }
    return true;
  }

  function handleSignin(event) {
    event.preventDefault();
    if (!verifyOTP('signin')) return;

    const contact = document.getElementById('signinContact').value.trim();
    let user = JSON.parse(localStorage.getItem('user'));

    if (!user || user.contact.trim().toLowerCase() !== contact.toLowerCase()) {
      alert('Account not found. Please sign up first.');
      return;
    }

    user.isLoggedIn = true;
    localStorage.setItem('user', JSON.stringify(user));
    currentUser = user;
    updateUIForLoggedIn(user);
    // Persist/ensure user exists on backend (optional if server running)
    fetch("/api/users/upsert", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name: user.name, contact: user.contact })
    }).catch(() => {});
    closeAuthModal();
  }

  function handleSignup(event) {
    event.preventDefault();
    if (!verifyOTP('signup')) return;

    const name = document.getElementById('signupName').value.trim();
    const contact = document.getElementById('signupContact').value.trim();
    const skills = document.getElementById('signupSkills').value.split(',').map(s => s.trim()).filter(Boolean);
    const hobbies = document.getElementById('signupHobbies').value.split(',').map(h => h.trim()).filter(Boolean);

    if (!name || !contact) {
      alert('Please enter both name and contact information.');
      return;
    }

    const user = {
      name,
      contact,
      isLoggedIn: true,
      skills: skills.length ? skills : [],
      hobbies: hobbies.length ? hobbies : []
    };

    localStorage.setItem('user', JSON.stringify(user));
    currentUser = user;
    updateUIForLoggedIn(user);
    // Create/update backend user record (optional if server running)
    fetch("/api/users/upsert", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name: user.name, contact: user.contact })
    }).catch(() => {});
    closeAuthModal();
  }

  function logout() {
    localStorage.removeItem('user');
    localStorage.removeItem('makeBigActiveProject');
    currentUser = null;
    appState.user = null;
    appState.role = null;
    appState.currentProject = null;
    appState.view = "home";
    document.getElementById('profileMenu').classList.remove('active');
    document.getElementById('profileContainer').classList.add('hidden');
    updateUIForLoggedOut('You have been logged out.');
    location.reload(); // Reload to reset all states
  }

  function handleStartProject() {
    if (!checkAuth()) {
      openAuth();
      setAuthMessage('Please login to create a project');
      return;
    }
    openProjectModal();
  }

  document.addEventListener('click', function(event) {
    const profileMenu = document.getElementById('profileMenu');
    const profileContainer = document.getElementById('profileContainer');
    if (!profileMenu || !profileContainer) return;
    if (!profileMenu.classList.contains('active')) return;
    if (!profileMenu.contains(event.target) && !profileContainer.contains(event.target)) {
      profileMenu.classList.remove('active');
    }
  });

  // Initialize auth check on page load
  window.onload = function() {
    checkAuth();
    renderApp();
    const navProjects = document.getElementById("navProjectsLink");
    if (navProjects) navProjects.addEventListener("click", handleNavbarProjectsNav);
    apiGetSeed();
    const SPLASH_MS = 3400;
    setTimeout(() => {
      hideSplash();
    }, SPLASH_MS);
  };

  // ================= PROJECT MODAL FUNCTIONALITY =================
  function openProjectModal() {
    const modal = document.getElementById("projectModal");
    modal.classList.add("active");
    document.body.style.overflow = "hidden";
    initProjectWizard();
  }

  function closeProjectModal() {
    const modal = document.getElementById("projectModal");
    modal.classList.remove("active");
    document.body.style.overflow = "auto";
    if (wizardState.quoteInterval) {
      clearInterval(wizardState.quoteInterval);
      wizardState.quoteInterval = null;
    }
  }

