# =============================================================================
# Make Big — Environment Variables
# Copy to .env for local dev. Never commit real .env / .env.local to GitHub.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# development | production
NODE_ENV=development

# Express listen port (Render sets PORT automatically — do not hardcode on Render)
PORT=5001

# Data backend: mongo (default, Express + MongoDB) | supabase
NEXT_PUBLIC_DATA_BACKEND=mongo

# -----------------------------------------------------------------------------
# MongoDB (required when NEXT_PUBLIC_DATA_BACKEND=mongo)
# -----------------------------------------------------------------------------

# Atlas connection string — server-side only, never NEXT_PUBLIC_
MONGODB_URI=
# Alias accepted by backend/db/connection.js
MONGO_URI=

# -----------------------------------------------------------------------------
# Supabase (required when NEXT_PUBLIC_DATA_BACKEND=supabase)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS for admin API routes
SUPABASE_SERVICE_ROLE_KEY=
# Alias for server routes
SUPABASE_URL=

# -----------------------------------------------------------------------------
# Auth (JWT — must match on Vercel AND Render for Mongo mode)
# -----------------------------------------------------------------------------

# Generate: openssl rand -base64 32
JWT_SECRET=

# -----------------------------------------------------------------------------
# URLs — split deploy (Vercel frontend + Render API)
# -----------------------------------------------------------------------------

# Browser: Express API origin (no trailing slash)
# Local: http://localhost:5001
# Production (Vercel): https://your-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5001

# Browser: Next.js app origin
# Local: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Render API only — primary allowed CORS origin (exact Vercel production URL)
FRONTEND_URL=http://localhost:3000

# Render API only — comma-separated extra origins (preview deploys, custom domains)
# Example: https://makebig-git-main-you.vercel.app,https://makebig.yourcollege.in
CORS_EXTRA_ORIGINS=

# Render API only — allow any *.vercel.app origin (preview branches)
CORS_ALLOW_VERCEL_PREVIEWS=false

# Render unified deploy only — serve Next.js from Express on same port (not used for Vercel+Render split)
SERVE_NEXT=false

# Set automatically when SERVE_NEXT=true — do not set manually
INTERNAL_API_URL=

# -----------------------------------------------------------------------------
# OTP / email / SMS
# -----------------------------------------------------------------------------

# true = OTP code may appear in API JSON (local beta only; set false in production)
ALLOW_DEV_OTP=true

# Resend.com for OTP email (works on Render free tier and Vercel)
RESEND_API_KEY=

# Verified sender — use onboarding@resend.dev for testing, or your domain after verifying at resend.com
EMAIL_FROM=Make Big <onboarding@resend.dev>

# Legacy Gmail SMTP (optional fallback — not recommended on Render free tier)
EMAIL_PASS=

# Fast2SMS for India SMS OTP (optional alternative to email)
FAST2SMS_API_KEY=

# -----------------------------------------------------------------------------
# AI Co-founder (Render API — Anthropic preferred; Groq fallback)
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# -----------------------------------------------------------------------------
# Stripe (Vercel Next.js API routes: /api/stripe/*)
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# -----------------------------------------------------------------------------
# Scripts / CI (local only — never deploy)
# -----------------------------------------------------------------------------

# scripts/push-github.mjs — GitHub PAT with repo write access
GITHUB_TOKEN=

# scripts/verify-deploy-ready.mjs — override API URL for health check
API_URL=
