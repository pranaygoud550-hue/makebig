# Make Big - Environment Variables Template
# Copy this to .env and fill in your actual values

PORT=5001
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@makebig.iyjcfym.mongodb.net/make-big?appName=makebig

# Auth - Generate with: openssl rand -base64 32
JWT_SECRET=generate_random_string_here

# CORS
FRONTEND_URL=http://localhost:3000

# OTP - Dev mode shows OTP in console
ALLOW_DEV_OTP=true

# Email OTP (production)
EMAIL_FROM=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# SMS OTP (production)
FAST2SMS_API_KEY=your_api_key

# AI
GROQ_API_KEY=your_groq_key
# Optional — default: llama-3.1-8b-instant (llama3-8b-8192 was retired)
GROQ_MODEL=llama-3.1-8b-instant

# Supabase (optional)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Next.js (copy to .env.local for local dev)
NEXT_PUBLIC_API_URL=http://localhost:5001
