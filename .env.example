# =============================================================================
# Make Big — copy to .env (API / local) and set the same values in Render + Vercel
# =============================================================================

# --- API server (Render / Railway / VPS) ---
PORT=5001
NODE_ENV=production

# MongoDB Atlas (required for production)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/make-big?retryWrites=true&w=majority

# Auth — use a long random string (openssl rand -base64 32)
# NEVER prefix with NEXT_PUBLIC_ — server only
JWT_SECRET=change-me-to-a-long-random-secret

# CORS — your live site URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# Optional: extra origins (comma-separated), e.g. custom domain + Vercel previews
# CORS_EXTRA_ORIGINS=https://www.makebig.in,https://make-big-git-main-you.vercel.app

# OTP — email (Gmail app password) and/or SMS (India)
EMAIL_FROM=your@gmail.com
EMAIL_PASS=your-gmail-app-password
FAST2SMS_API_KEY=

# Production: do NOT set unless you intentionally want on-screen OTP codes
# ALLOW_DEV_OTP=true

# AI (Pro live responses — optional)
GROQ_API_KEY=

# --- Next.js (Vercel) — prefix NEXT_PUBLIC_ is exposed to the browser ---
NEXT_PUBLIC_API_URL=https://your-api.onrender.com
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# OTP on Vercel (same as above — used by /api/auth/send-otp)
# EMAIL_FROM=
# EMAIL_PASS=
# FAST2SMS_API_KEY=

# Stripe Pro (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
# STRIPE_SECRET_KEY must also be on Vercel for /api/stripe/*

# Supabase — only if you switch from Mongo (leave empty for Mongo + Express path)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
