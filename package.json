{
  "name": "make-big",
  "version": "2.0.0",
  "description": "Modern project collaboration platform built with Next.js and React",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/kill-dev-ports.mjs && node scripts/dev-all.mjs",
    "dev:next": "node scripts/kill-dev-ports.mjs && next dev -p 3000",
    "dev:all": "node scripts/kill-dev-ports.mjs && node scripts/dev-all.mjs",
    "dev:clean": "node scripts/kill-dev-ports.mjs && rm -rf .next && next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "api:dev": "node server-new.js",
    "api:prod": "NODE_ENV=production node server-new.js",
    "start:render": "SERVE_NEXT=true NODE_ENV=production node server-new.js",
    "dev:full": "node server-new.js & next dev",
    "verify:deploy": "node scripts/verify-deploy-ready.mjs",
    "push:github": "node scripts/push-github.mjs",
    "deploy:env": "node scripts/generate-deploy-env.mjs",
    "seed:demo": "node scripts/seed-demo.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.106.0",
    "autoprefixer": "^10.4.17",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "groq-sdk": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.0.0",
    "mongoose": "^7.8.9",
    "next": "^14.2.0",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "stripe": "^17.7.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.19",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^5.4.5"
  }
}
